{
	"compatibility_date": "2026-04-05",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "snowbound",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{ "pattern": "snowboundbg.com/*", "zone_name": "snowboundbg.com" },
		{ "pattern": "www.snowboundbg.com/*", "zone_name": "snowboundbg.com" }
	]
}

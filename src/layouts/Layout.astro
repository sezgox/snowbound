---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Snowbound — Strategic board game",
	description =
		"Survive the winter. Betray your rivals. A strategic board game of exploration, deception and survival.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/images/figma/nav-logo.png" />
		<link rel="icon" href="/images/figma/nav-logo.png" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Nunito+Sans:ital,wght@0,400;0,700;1,400&family=Roboto:wght@400;700&family=Tillana:wght@500;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

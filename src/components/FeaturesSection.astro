---
import type { Messages } from "../i18n";

interface Props {
	messages: Messages["features"];
}

const { messages } = Astro.props;
const cards = messages.cards;
---

<section
	id="features"
	class="relative w-full scroll-mt-0 overflow-x-clip"
	style="background-image: url('/images/figma/hex-board.png'); background-size: cover; background-position: center; background-repeat: no-repeat; background-attachment: fixed;"
	aria-labelledby="features-heading"
>
	<div class="pointer-events-none absolute inset-0 z-0 bg-white/[0.66]" aria-hidden="true" />

	<div
		class="section-inner relative z-10 flex w-full items-start justify-center px-4 py-6 md:px-6 md:py-10"
	>
		<div class="features-board">
			<h2
				id="features-heading"
				class="features-title-wrap font-display text-shadow-outline text-shadow-white text-center tracking-wide text-[#112d57] drop-shadow-[0_4px_6px_rgba(0,0,0,0.25)]"
			>
				{messages.heading}
			</h2>

			<div class="features-cards-grid w-full">
				{
					cards.map((card) => (
						<div class="features-card-slot flex w-full justify-center">
							<div class="features-card-surface">
								<div class="features-card-title font-tillana">
									{card.titleLines.map((line) => (
										<p class="mb-0 leading-inherit">{line}</p>
									))}
								</div>
								<p class="features-card-body font-nunito">
									{card.body}
								</p>
							</div>
						</div>
					))
				}
			</div>

			<div class="features-media-slot w-full">
				<div class="features-media-frame">
					<img
						class="features-media-img"
						src={messages.mediaImageSrc}
						alt={messages.mediaAlt}
						loading="lazy"
						decoding="async"
						width="760"
						height="400"
					/>
				</div>
			</div>

			<div class="features-cta-wrap relative flex w-full justify-center">
				<button
					type="button"
					data-open-waitlist
					class="font-tillana flex w-full items-center justify-center rounded-[50px] bg-snowbound-primary px-4 py-2.5 text-lg leading-none tracking-tight text-white shadow-[0_4px_31px_rgba(0,0,0,0.15)] transition hover:bg-[#0270c2] max-md:min-h-[52px] max-md:whitespace-nowrap md:h-[78px] md:text-[48px] md:leading-8 md:tracking-[0.1px]"
				>
					{messages.cta}
				</button>
			</div>
		</div>
	</div>
</section>

<style>
	#features {
		--features-card-slot-width: min(100%, 148px);
		--features-card-slot-height: 176px;
	}

	@media (min-width: 768px) {
		#features {
			--features-card-slot-width: min(100%, 208px);
			--features-card-slot-height: 196px;
		}
	}

	.features-board {
		display: flex;
		width: 100%;
		max-width: 100%;
		flex-direction: column;
		align-items: center;
		gap: clamp(0.8rem, 1.8vw, 1.4rem);
		padding-block: clamp(1rem, 3svh, 2rem) clamp(1.5rem, 4svh, 3rem);
	}

	.features-title-wrap {
		width: min(100%, 720px);
		margin: 0;
		padding: 0.5rem 1rem;
		font-size: clamp(2.25rem, 6vw, 4rem);
		line-height: 1.1;
	}

	@media (min-width: 1024px) {
		.features-title-wrap {
			width: auto;
			max-width: calc(100vw - 3rem);
			white-space: nowrap;
		}
	}

	.features-cards-grid {
		display: grid;
		width: 100%;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		justify-items: center;
	}

	@media (min-width: 768px) {
		.features-cards-grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
			gap: 1rem;
		}
	}

	.features-card-surface {
		box-sizing: border-box;
		display: flex;
		width: min(100%, var(--features-card-slot-width));
		height: var(--features-card-slot-height);
		aspect-ratio: 37 / 44;
		flex-shrink: 0;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: clamp(0.55rem, 1.5vw, 1rem);
		border-radius: 10px;
		border: 1px solid #77abbd;
		background: rgba(255, 255, 255, 0.96);
		padding: 0.9rem 0.8rem;
		box-shadow: 0 10px 28px rgba(17, 45, 87, 0.12);
		overflow: hidden;
	}

	.features-card-title {
		width: 100%;
		margin: 0;
		text-align: center;
		font-size: 0.98rem;
		font-weight: 700;
		line-height: 1.22;
		letter-spacing: 0.02em;
		color: #000;
		text-wrap: balance;
	}

	.features-card-body {
		width: 100%;
		margin: 0;
		text-align: center;
		font-size: 0.9rem;
		line-height: 1.45;
		letter-spacing: 0.01em;
		color: #5c5c5c;
		text-wrap: balance;
	}

	@media (min-width: 768px) {
		.features-card-surface {
			gap: clamp(0.75rem, 1.8vw, 1.25rem);
			padding: 1rem 0.95rem;
		}

		.features-card-title {
			font-size: 1.25rem;
			line-height: 1.2;
		}

		.features-card-body {
			font-size: 0.94rem;
			line-height: 1.45;
		}
	}

	.features-media-frame {
		position: relative;
		overflow: hidden;
		height: clamp(104px, 17vh, 124px);
		width: 100%;
		border-radius: 18px;
		border: 1px solid rgba(119, 171, 189, 0.9);
		background:
			linear-gradient(135deg, rgba(17, 45, 87, 0.14), rgba(2, 133, 228, 0.26)),
			rgba(255, 255, 255, 0.88);
		box-shadow: 0 10px 28px rgba(17, 45, 87, 0.12);
	}

	.features-media-img {
		display: block;
		height: 100%;
		width: 100%;
		object-fit: cover;
		object-position: center;
	}

	@media (min-width: 768px) {
		.features-media-frame {
			height: clamp(150px, 20vh, 188px);
		}
	}

	.features-media-slot {
		width: min(100%, 760px);
		view-timeline-name: --features-media-slot;
		view-timeline-axis: block;
		animation-timeline: --features-media-slot;
		animation-name: show;
		animation-fill-mode: both;
		animation-range: entry 20% cover 35%;
		@media (max-width: 768px) {
			animation-range: entry 10% cover 20%;
		}
	}

	.features-cta-wrap {
		width: min(100%, 760px);
		view-timeline-name: --features-cta;
		view-timeline-axis: block;
		animation-timeline: --features-cta;
		animation-name: show;
		animation-fill-mode: both;
		animation-range: entry 20% cover 35%;
		@media (max-width: 768px) {
			animation-range: entry 0% cover 15%;
		}
	}

	.features-card-slot {
		view-timeline-name: --features-card-slot;
		view-timeline-axis: block;
		animation-timeline: --features-card-slot;
		animation-name: show;
		animation-fill-mode: both;
		animation-range: entry 20% cover 35%;
		@media (max-width: 768px) {
			animation-range: entry 10% cover 20%;
		}
	}

	#features h2 {
		animation-timeline: --features;
		animation-name: show;
		animation-fill-mode: both;
		animation-range: entry 20% cover 35%;
		@media (max-width: 768px) {
			animation-range: entry 10% cover 20%;
		}
	}

	#features {
		view-timeline-name: --features;
		view-timeline-axis: block;
	}


	@keyframes show {
		0% {
			opacity: 0;
			transform: translateY(300px);
		}

		100% {
			opacity: 1;
			transform: translateY(0);
		}
	}

</style>


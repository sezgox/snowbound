---
const cards = [
	{
		title: ["CHANGING", "BOARD"],
		body: "Break the ice and reveal a new map every game",
	},
	{
		title: ["HIGH PLAYER", "INTERACTION"],
		body: "Steal, block and outplay your rivals at every turn.",
	},
	{
		title: ["RISK VS REWARD"],
		body: "Push your luck... or play it safe and lose the race.",
	},
	{
		title: ["2 PATHS TO", "VICTORIES"],
		body: "You don't need to follow everyone else's path.",
	},
] as const;
---

<section
	id="features"
	class="features-scroll-track relative w-full scroll-mt-0"
	style="min-height: 100dvh; background-image: url('/images/figma/hex-board.png'); background-size: cover; background-position: center; background-repeat: no-repeat; background-attachment: fixed;"
	aria-labelledby="features-heading"
	data-features-scroll
	data-features-stage="entry-pending"
	data-features-step-index="-1"
	data-page-snap="start"
>
	<div class="pointer-events-none absolute inset-0 z-0 bg-white/[0.66]" aria-hidden="true" />

	<div class="features-shell relative z-10 flex min-h-[100dvh] w-full items-center justify-center overflow-hidden py-4 md:py-8">
		<div class="pointer-events-none fixed inset-0 z-40" aria-hidden="true">
			<p
				class="features-overlay-item features-overlay-item--title font-display text-shadow-outline text-shadow-white text-center tracking-wide text-[#112d57]"
				data-features-overlay-item="title"
				hidden
			>
				WHAT MAKES IT UNIQUE
			</p>

			{
				cards.map((card, index) => (
					<div
						class="features-overlay-item features-overlay-item--card"
						data-features-overlay-item={`card-${index}`}
						hidden
					>
						<div class="features-card-surface features-card-surface--overlay">
							<div class="features-card-title font-tillana">
								{card.title.map((line) => (
									<p class="mb-0 leading-inherit">{line}</p>
								))}
							</div>
							<p class="features-card-body font-nunito">
								{card.body}
							</p>
						</div>
					</div>
				))
			}

			<div
				class="features-overlay-item features-overlay-item--media"
				data-features-overlay-item="media"
				hidden
			>
				<div class="features-media-frame" aria-hidden="true"></div>
			</div>
		</div>

		<div class="section-inner relative z-10 flex min-h-[100dvh] w-full items-center justify-center px-4 py-4 md:py-6">
			<div class="features-board">
				<h2
					id="features-heading"
					class="features-title-wrap features-slot-item font-display text-shadow-outline text-shadow-white text-center tracking-wide text-[#112d57] drop-shadow-[0_4px_6px_rgba(0,0,0,0.25)]"
					data-features-slot-item="title"
					data-features-placed="false"
				>
					WHAT MAKES IT UNIQUE
				</h2>

				<div class="features-cards-grid" data-features-cards>
					{
						cards.map((card, index) => (
							<div
								class="features-card-slot features-slot-item"
								data-features-slot-item={`card-${index}`}
								data-features-placed="false"
							>
								<div class="features-card-surface features-card-surface--slot">
									<div class="features-card-title font-tillana">
										{card.title.map((line) => (
											<p class="mb-0 leading-inherit">{line}</p>
										))}
									</div>
									<p class="features-card-body font-nunito">
										{card.body}
									</p>
								</div>
							</div>
						))
					}
				</div>

				<div
					class="features-media-slot features-slot-item"
					data-features-slot-item="media"
					data-features-placed="false"
				>
					<div class="features-media-frame" aria-hidden="true"></div>
				</div>

				<div
					class="features-cta-wrap relative flex w-full justify-center"
					data-features-cta
					data-features-visible="false"
				>
					<button
						type="button"
						data-open-waitlist
						class="font-tillana flex w-full max-w-[min(100%,778px)] items-center justify-center rounded-[50px] bg-snowbound-primary px-4 py-2.5 text-lg leading-none tracking-tight text-white shadow-[0_4px_31px_rgba(0,0,0,0.15)] transition hover:bg-[#0270c2] max-md:min-h-[52px] max-md:whitespace-nowrap md:h-[78px] md:px-[70px] md:py-0 md:text-[48px] md:leading-8 md:tracking-[0.1px]"
					>
						JOIN THE WAITLIST
					</button>
				</div>
			</div>
		</div>

		<p
			class="features-scroll-hint pointer-events-none fixed bottom-8 left-1/2 z-40 md:bottom-10"
			aria-hidden="true"
			data-features-scroll-hint
			hidden
		>
			<span class="features-scroll-hint__pill font-nunito">
				<span class="features-scroll-hint__icon" aria-hidden="true">&darr;</span>
				Keep scrolling
			</span>
		</p>
	</div>
</section>

<noscript>
	<style>
		#features [data-features-overlay-item],
		#features .features-scroll-hint {
			display: none !important;
		}

		#features [data-features-slot-item],
		#features [data-features-cta] {
			opacity: 1 !important;
			visibility: visible !important;
			transform: none !important;
			pointer-events: auto !important;
		}
	</style>
</noscript>

<style>
	#features[data-features-scroll] {
		--features-card-slot-width: min(100%, 148px);
		--features-card-slot-height: 176px;
		--features-card-center-scale: 1.82;
		--features-media-center-scale: 1.16;
	}

	@media (min-width: 768px) {
		#features[data-features-scroll] {
			--features-card-slot-width: min(100%, 208px);
			--features-card-slot-height: 196px;
			--features-card-center-scale: 1.46;
			--features-media-center-scale: 1.08;
		}
	}

	.features-board {
		display: flex;
		width: 100%;
		flex-direction: column;
		align-items: center;
		gap: clamp(0.8rem, 1.8vw, 1.4rem);
	}

	.features-title-wrap {
		width: min(100%, 720px);
		margin: 0;
		padding: 0.5rem 1rem;
		font-size: clamp(2.25rem, 6vw, 4rem);
		line-height: 1.1;
	}

	.features-cards-grid {
		display: grid;
		width: 100%;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		justify-items: center;
	}

	@media (min-width: 768px) {
		.features-cards-grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
			gap: 1rem;
		}
	}

	.features-card-slot {
		display: flex;
		width: 100%;
		justify-content: center;
	}

	.features-card-surface {
		box-sizing: border-box;
		display: flex;
		width: min(100%, var(--features-card-slot-width));
		height: var(--features-card-slot-height);
		aspect-ratio: 37 / 44;
		flex-shrink: 0;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: clamp(0.55rem, 1.5vw, 1rem);
		border-radius: 10px;
		border: 1px solid #77abbd;
		background: rgba(255, 255, 255, 0.96);
		padding: 0.9rem 0.8rem;
		box-shadow: 0 10px 28px rgba(17, 45, 87, 0.12);
		overflow: hidden;
	}

	.features-card-surface--overlay {
		box-shadow:
			0 26px 64px rgba(17, 45, 87, 0.26),
			0 10px 26px rgba(0, 0, 0, 0.16);
	}

	.features-card-title {
		width: 100%;
		margin: 0;
		text-align: center;
		font-size: 0.98rem;
		font-weight: 700;
		line-height: 1.22;
		letter-spacing: 0.02em;
		color: #000;
		text-wrap: balance;
	}

	.features-card-body {
		width: 100%;
		margin: 0;
		text-align: center;
		font-size: 0.9rem;
		line-height: 1.45;
		letter-spacing: 0.01em;
		color: #5c5c5c;
		text-wrap: balance;
	}

	@media (min-width: 768px) {
		.features-card-surface {
			gap: clamp(0.75rem, 1.8vw, 1.25rem);
			padding: 1rem 0.95rem;
		}

		.features-card-title {
			font-size: 1.25rem;
			line-height: 1.2;
		}

		.features-card-body {
			font-size: 0.94rem;
			line-height: 1.45;
		}
	}

	.features-media-slot {
		width: min(100%, 760px);
	}

	.features-media-frame {
		height: clamp(104px, 17vh, 124px);
		width: 100%;
		border-radius: 18px;
		border: 1px solid rgba(119, 171, 189, 0.9);
		background:
			linear-gradient(135deg, rgba(17, 45, 87, 0.14), rgba(2, 133, 228, 0.26)),
			rgba(255, 255, 255, 0.88);
		box-shadow: 0 10px 28px rgba(17, 45, 87, 0.12);
	}

	@media (min-width: 768px) {
		.features-media-frame {
			height: clamp(150px, 20vh, 188px);
		}
	}

	.features-slot-item {
		opacity: 0;
		visibility: hidden;
		transform: scale(0.96);
		transition:
			opacity 0.28s ease,
			transform 0.48s cubic-bezier(0.22, 1, 0.36, 1),
			visibility 0s linear 0.28s;
	}

	.features-slot-item[data-features-placed="true"] {
		opacity: 1;
		visibility: visible;
		transform: none;
		transition-delay: 0s;
	}

	.features-cta-wrap {
		width: min(100%, 760px);
		opacity: 0;
		visibility: hidden;
		transform: translate3d(0, 0.75rem, 0);
		pointer-events: none;
		transition:
			opacity 0.3s ease,
			transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
			visibility 0s linear 0.3s;
	}

	.features-cta-wrap[data-features-visible="true"] {
		opacity: 1;
		visibility: visible;
		transform: none;
		pointer-events: auto;
		transition-delay: 0s;
	}

	.features-overlay-item {
		position: fixed;
		left: 50%;
		top: 50%;
		margin: 0;
		opacity: 0;
		transform: translate3d(-50%, -50%, 0) scale(1);
		transition:
			left 0.72s cubic-bezier(0.22, 1, 0.36, 1),
			top 0.72s cubic-bezier(0.22, 1, 0.36, 1),
			transform 0.72s cubic-bezier(0.22, 1, 0.36, 1),
			opacity 0.32s ease;
		will-change: left, top, transform, opacity;
	}

	.features-overlay-item[data-immediate="true"] {
		transition: none !important;
	}

	.features-overlay-item--title {
		width: min(92vw, 920px);
		padding: 0.5rem 1rem;
		font-size: clamp(2.25rem, 7.5vw, 4rem);
		line-height: 1.05;
	}

	@media (min-width: 1024px) {
		.features-title-wrap,
		.features-overlay-item--title {
			width: auto;
			max-width: calc(100vw - 3rem);
			white-space: nowrap;
		}
	}

	.features-overlay-item--card {
		width: min(92vw, var(--features-card-slot-width));
	}

	.features-overlay-item--media {
		width: min(92vw, 760px);
	}

	.features-scroll-hint {
		transform: translateX(-50%);
		opacity: 0;
		visibility: hidden;
		transition:
			opacity 0.35s ease,
			visibility 0s linear 0.35s;
	}

	#features[data-features-stage="intro"] .features-scroll-hint {
		opacity: 1;
		visibility: visible;
		transition-delay: 0s;
	}

	.features-scroll-hint__pill {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 0.75rem 1.35rem;
		border-radius: 9999px;
		background: var(--color-snowbound-primary);
		color: #fff;
		font-size: clamp(0.8rem, 2.4vw, 1rem);
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		border: 2px solid rgba(255, 255, 255, 0.4);
		box-shadow:
			0 10px 32px rgba(2, 133, 228, 0.45),
			0 4px 14px rgba(0, 0, 0, 0.18),
			inset 0 1px 0 rgba(255, 255, 255, 0.2);
		text-shadow: 0 1px 0 rgba(0, 0, 0, 0.12);
		white-space: nowrap;
	}

	.features-scroll-hint__icon {
		font-size: 1.1em;
		line-height: 1;
		animation: features-hint-bounce 1.1s ease-in-out infinite;
	}

	@keyframes features-hint-bounce {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(4px);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		#features [data-features-overlay-item],
		#features .features-scroll-hint {
			display: none !important;
		}

		#features [data-features-slot-item],
		#features [data-features-cta] {
			opacity: 1 !important;
			visibility: visible !important;
			transform: none !important;
			pointer-events: auto !important;
		}
	}
</style>

<script is:inline>
	const FEATURES_STAGE_ENTRY_PENDING = "entry-pending";
	const FEATURES_STAGE_INTRO_PREP = "intro-prep";
	const FEATURES_STAGE_INTRO = "intro";
	const FEATURES_STAGE_SEQUENCE = "sequence";
	const FEATURES_STAGE_COMPLETE = "complete";
	const FEATURES_STAGE_EXIT_UP = "exit-up";
	const FEATURES_ENTRY_RULE_ID = "lore-to-features";
	const FEATURES_STEP_LOCK_ID = "features-sequence-step";
	const FEATURES_EXIT_TO_LORE_LOCK_ID = "features-intro-back-to-lore";
	const FEATURES_LOCK_DURATION_MS = 720;
	const FEATURES_WHEEL_THRESHOLD = 44;
	const FEATURES_TOUCH_THRESHOLD = 40;
	const FEATURES_CONTROL_TOP_TOLERANCE_PX = 120;
	const FEATURES_SEQUENCE_STEPS = [
		{ item: "card-0", phase: "center" },
		{ item: "card-0", phase: "slot" },
		{ item: "card-1", phase: "center" },
		{ item: "card-1", phase: "slot" },
		{ item: "card-2", phase: "center" },
		{ item: "card-2", phase: "slot" },
		{ item: "card-3", phase: "center" },
		{ item: "card-3", phase: "slot" },
		{ item: "media", phase: "center" },
		{ item: "media", phase: "slot" },
	];
	const FEATURES_ITEMS = ["title", "card-0", "card-1", "card-2", "card-3", "media"];
	let featuresSequenceCompletedThisLoad = false;

	function isHomepageScrollSnapLocked() {
		return Boolean(document.documentElement.dataset.scrollSnapLock);
	}

	function setHomepageScrollSnapLock(ruleId) {
		const root = document.documentElement;

		if (ruleId) {
			root.dataset.scrollSnapLock = ruleId;
		} else {
			delete root.dataset.scrollSnapLock;
		}

		document.dispatchEvent(
			new CustomEvent("snowbound:scroll-snap-lock-change", {
				detail: { ruleId },
			}),
		);
	}

	function getFeaturesStage(section) {
		return section.dataset.featuresStage ?? FEATURES_STAGE_ENTRY_PENDING;
	}

	function setFeaturesStage(section, stage) {
		section.dataset.featuresStage = stage;

		const scrollHint = section.querySelector("[data-features-scroll-hint]");
		if (scrollHint instanceof HTMLElement) {
			scrollHint.hidden = stage !== FEATURES_STAGE_INTRO;
		}
	}

	function getFeaturesStepIndex(section) {
		return Number(section.dataset.featuresStepIndex ?? "-1");
	}

	function setFeaturesStepIndex(section, stepIndex) {
		section.dataset.featuresStepIndex = String(stepIndex);
	}

	function getFeaturesOverlay(section, itemId) {
		return section.querySelector(`[data-features-overlay-item="${itemId}"]`);
	}

	function getFeaturesSlot(section, itemId) {
		return section.querySelector(`[data-features-slot-item="${itemId}"]`);
	}

	function getFeaturesCta(section) {
		return section.querySelector("[data-features-cta]");
	}

	function getFeaturesSequenceStep(stepIndex) {
		return FEATURES_SEQUENCE_STEPS[stepIndex] ?? null;
	}

	function getFeaturesCenterPoint() {
		const { clientWidth, clientHeight } = document.documentElement;
		return {
			x: (clientWidth || window.innerWidth) / 2,
			y: (clientHeight || window.innerHeight) / 2,
		};
	}

	function getFeaturesOffscreenPoint() {
		const center = getFeaturesCenterPoint();
		return {
			x: center.x,
			y: center.y + window.innerHeight * 0.18,
		};
	}

	function getFeaturesSlotCenter(section, itemId) {
		const slot = getFeaturesSlot(section, itemId);
		if (!(slot instanceof HTMLElement)) {
			return getFeaturesCenterPoint();
		}

		const rect = slot.getBoundingClientRect();
		return {
			x: rect.left + rect.width / 2,
			y: rect.top + rect.height / 2,
		};
	}

	function getFeaturesCenterScale(itemId) {
		if (itemId.startsWith("card-")) {
			return window.matchMedia("(min-width: 768px)").matches ? 1.46 : 1.82;
		}

		if (itemId === "media") {
			return window.matchMedia("(min-width: 768px)").matches ? 1.08 : 1.16;
		}

		return 1;
	}

	function getPlacedItemsForSequenceStep(stepIndex) {
		const placedItems = new Set(["title"]);

		for (let index = 0; index <= stepIndex; index += 1) {
			const step = getFeaturesSequenceStep(index);
			if (step?.phase === "slot") {
				placedItems.add(step.item);
			}
		}

		return placedItems;
	}

	function hideAllFeaturesOverlays(section) {
		section.querySelectorAll("[data-features-overlay-item]").forEach((overlay) => {
			if (!(overlay instanceof HTMLElement)) return;
			overlay.hidden = true;
			setFeaturesOverlayImmediate(overlay, true);
			overlay.style.opacity = "0";
		});
	}

	function setFeaturesOverlayImmediate(overlay, immediate) {
		overlay.dataset.immediate = immediate ? "true" : "false";
	}

	function positionFeaturesOverlay(overlay, state) {
		overlay.style.left = `${state.x}px`;
		overlay.style.top = `${state.y}px`;
		overlay.style.opacity = String(state.opacity);
		overlay.style.transform = `translate3d(-50%, -50%, 0) scale(${state.scale})`;
	}

	function prepareFeaturesOverlay(section, itemId, state, immediate = false) {
		const overlay = getFeaturesOverlay(section, itemId);
		if (!(overlay instanceof HTMLElement)) return null;

		overlay.hidden = false;
		setFeaturesOverlayImmediate(overlay, immediate);
		positionFeaturesOverlay(overlay, state);
		return overlay;
	}

	function showFeaturesOverlay(section, itemId, state, immediate = false) {
		hideAllFeaturesOverlays(section);
		return prepareFeaturesOverlay(section, itemId, state, immediate);
	}

	function syncFeaturesPlacedItems(section) {
		const stage = getFeaturesStage(section);
		const stepIndex = getFeaturesStepIndex(section);
		const placedItems =
			stage === FEATURES_STAGE_COMPLETE
				? new Set(FEATURES_ITEMS)
				: stage === FEATURES_STAGE_SEQUENCE
					? getPlacedItemsForSequenceStep(stepIndex)
					: new Set();

		FEATURES_ITEMS.forEach((itemId) => {
			const slot = getFeaturesSlot(section, itemId);
			if (!(slot instanceof HTMLElement)) return;
			slot.dataset.featuresPlaced = placedItems.has(itemId) ? "true" : "false";
		});

		const cta = getFeaturesCta(section);
		if (cta instanceof HTMLElement) {
			cta.dataset.featuresVisible = stage === FEATURES_STAGE_COMPLETE ? "true" : "false";
		}
	}

	function syncFeaturesStableVisuals(section) {
		syncFeaturesPlacedItems(section);

		const stage = getFeaturesStage(section);
		const step = getFeaturesSequenceStep(getFeaturesStepIndex(section));

		if (stage === FEATURES_STAGE_INTRO) {
			showFeaturesOverlay(section, "title", {
				...getFeaturesCenterPoint(),
				scale: 1,
				opacity: 1,
			}, true);
			return;
		}

		if (stage === FEATURES_STAGE_SEQUENCE && step?.phase === "center") {
			showFeaturesOverlay(section, step.item, {
				...getFeaturesCenterPoint(),
				scale: getFeaturesCenterScale(step.item),
				opacity: 1,
			}, true);
			return;
		}

		hideAllFeaturesOverlays(section);
	}

	function isFeaturesStableStage(stage) {
		return (
			stage === FEATURES_STAGE_ENTRY_PENDING ||
			stage === FEATURES_STAGE_INTRO ||
			stage === FEATURES_STAGE_SEQUENCE ||
			stage === FEATURES_STAGE_COMPLETE
		);
	}

	function isFeaturesTransientStage(stage) {
		return (
			stage === FEATURES_STAGE_INTRO_PREP ||
			stage === FEATURES_STAGE_EXIT_UP
		);
	}

	let featuresAnimationTimeoutId = null;
	let featuresAnimationSessionId = 0;
	const featuresAnimationFrameIds = new Set();

	function clearFeaturesAnimationTimeout() {
		if (featuresAnimationTimeoutId === null) return;
		window.clearTimeout(featuresAnimationTimeoutId);
		featuresAnimationTimeoutId = null;
	}

	function clearFeaturesAnimationFrames() {
		for (const frameId of featuresAnimationFrameIds) {
			window.cancelAnimationFrame(frameId);
		}

		featuresAnimationFrameIds.clear();
	}

	function queueFeaturesAnimationFrame(callback) {
		const frameId = window.requestAnimationFrame(() => {
			featuresAnimationFrameIds.delete(frameId);
			callback();
		});

		featuresAnimationFrameIds.add(frameId);
		return frameId;
	}

	function beginFeaturesAnimationSession() {
		clearFeaturesAnimationTimeout();
		return ++featuresAnimationSessionId;
	}

	function invalidateFeaturesAnimationSession() {
		featuresAnimationSessionId += 1;
		clearFeaturesAnimationTimeout();
		clearFeaturesAnimationFrames();
	}

	function animateFeaturesOverlay(section, itemId, fromState, toState, onDone) {
		const sessionId = beginFeaturesAnimationSession();
		const overlay = showFeaturesOverlay(section, itemId, fromState, true);
		if (!(overlay instanceof HTMLElement)) {
			onDone();
			return;
		}

		queueFeaturesAnimationFrame(() => {
			if (sessionId !== featuresAnimationSessionId) return;

			queueFeaturesAnimationFrame(() => {
				if (sessionId !== featuresAnimationSessionId) return;
				setFeaturesOverlayImmediate(overlay, false);
				positionFeaturesOverlay(overlay, toState);
			});
		});

		featuresAnimationTimeoutId = window.setTimeout(() => {
			featuresAnimationTimeoutId = null;
			if (sessionId !== featuresAnimationSessionId) return;
			onDone();
		}, FEATURES_LOCK_DURATION_MS);
	}

	function animateFeaturesOverlays(section, overlayConfigs, onDone) {
		const sessionId = beginFeaturesAnimationSession();
		hideAllFeaturesOverlays(section);

		const overlays = overlayConfigs
			.map((config) => {
				const overlay = prepareFeaturesOverlay(
					section,
					config.itemId,
					config.fromState,
					true,
				);
				return overlay ? { overlay, toState: config.toState } : null;
			})
			.filter(Boolean);

		if (!overlays.length) {
			onDone();
			return;
		}

		queueFeaturesAnimationFrame(() => {
			if (sessionId !== featuresAnimationSessionId) return;

			queueFeaturesAnimationFrame(() => {
				if (sessionId !== featuresAnimationSessionId) return;
				overlays.forEach(({ overlay, toState }) => {
					setFeaturesOverlayImmediate(overlay, false);
					positionFeaturesOverlay(overlay, toState);
				});
			});
		});

		featuresAnimationTimeoutId = window.setTimeout(() => {
			featuresAnimationTimeoutId = null;
			if (sessionId !== featuresAnimationSessionId) return;
			onDone();
		}, FEATURES_LOCK_DURATION_MS);
	}

	function runFeaturesIntroEntry(section) {
		const fromState = {
			...getFeaturesOffscreenPoint(),
			scale: 1,
			opacity: 0,
		};
		const toState = {
			...getFeaturesCenterPoint(),
			scale: 1,
			opacity: 1,
		};

		animateFeaturesOverlay(section, "title", fromState, toState, () => {
			setFeaturesStage(section, FEATURES_STAGE_INTRO);
			syncFeaturesStableVisuals(section);
			featuresSequenceAnimating = false;
		});
	}

	function transitionFeaturesStep(section, direction) {
		const stage = getFeaturesStage(section);
		const stepIndex = getFeaturesStepIndex(section);
		const currentStep = getFeaturesSequenceStep(stepIndex);

		if (direction === "down") {
			if (stage === FEATURES_STAGE_INTRO) {
				setFeaturesStage(section, FEATURES_STAGE_SEQUENCE);
				setFeaturesStepIndex(section, 0);

				animateFeaturesOverlays(
					section,
					[
						{
							itemId: "title",
							fromState: {
								...getFeaturesCenterPoint(),
								scale: 1,
								opacity: 1,
							},
							toState: {
								...getFeaturesSlotCenter(section, "title"),
								scale: 1,
								opacity: 1,
							},
						},
						{
							itemId: "card-0",
							fromState: {
								...getFeaturesOffscreenPoint(),
								scale: getFeaturesCenterScale("card-0") * 0.92,
								opacity: 0,
							},
							toState: {
								...getFeaturesCenterPoint(),
								scale: getFeaturesCenterScale("card-0"),
								opacity: 1,
							},
						},
					],
					() => {
						syncFeaturesStableVisuals(section);
						setHomepageScrollSnapLock(null);
						featuresSequenceAnimating = false;
					},
				);
				return;
			}

			if (stage === FEATURES_STAGE_SEQUENCE) {
				const nextStepIndex = stepIndex + 1;
				const nextStep = getFeaturesSequenceStep(nextStepIndex);

				if (!nextStep) {
					resolveFeaturesSequenceComplete(section, true);
					setHomepageScrollSnapLock(null);
					featuresSequenceAnimating = false;
					return;
				}

				setFeaturesStepIndex(section, nextStepIndex);
				setFeaturesStage(section, FEATURES_STAGE_SEQUENCE);

				if (nextStep.phase === "center") {
					syncFeaturesPlacedItems(section);
					animateFeaturesOverlay(
						section,
						nextStep.item,
						{
							...getFeaturesOffscreenPoint(),
							scale: getFeaturesCenterScale(nextStep.item) * 0.92,
							opacity: 0,
						},
						{
							...getFeaturesCenterPoint(),
							scale: getFeaturesCenterScale(nextStep.item),
							opacity: 1,
						},
						() => {
							syncFeaturesStableVisuals(section);
							setHomepageScrollSnapLock(null);
							featuresSequenceAnimating = false;
						},
					);
					return;
				}

				if (currentStep?.phase === "center" && currentStep.item === nextStep.item) {
					animateFeaturesOverlay(
						section,
						currentStep.item,
						{
							...getFeaturesCenterPoint(),
							scale: getFeaturesCenterScale(currentStep.item),
							opacity: 1,
						},
						{
							...getFeaturesSlotCenter(section, currentStep.item),
							scale: 1,
							opacity: 1,
						},
						() => {
							syncFeaturesStableVisuals(section);
							setHomepageScrollSnapLock(null);
							featuresSequenceAnimating = false;
						},
					);
					return;
				}
			}
		}

		if (direction === "up") {
			if (stage === FEATURES_STAGE_COMPLETE) {
				setFeaturesStage(section, FEATURES_STAGE_SEQUENCE);
				setFeaturesStepIndex(section, FEATURES_SEQUENCE_STEPS.length - 1);
				syncFeaturesStableVisuals(section);
				setHomepageScrollSnapLock(null);
				featuresSequenceAnimating = false;
				return;
			}

			if (stage === FEATURES_STAGE_SEQUENCE) {
				if (currentStep?.phase === "slot") {
					setFeaturesStepIndex(section, stepIndex - 1);
					setFeaturesStage(section, FEATURES_STAGE_SEQUENCE);
					syncFeaturesPlacedItems(section);

					animateFeaturesOverlay(
						section,
						currentStep.item,
						{
							...getFeaturesSlotCenter(section, currentStep.item),
							scale: 1,
							opacity: 1,
						},
						{
							...getFeaturesCenterPoint(),
							scale: getFeaturesCenterScale(currentStep.item),
							opacity: 1,
						},
						() => {
							syncFeaturesStableVisuals(section);
							setHomepageScrollSnapLock(null);
							featuresSequenceAnimating = false;
						},
					);
					return;
				}

				if (currentStep?.phase === "center") {
					if (stepIndex === 0 && currentStep.item === "card-0") {
						setFeaturesStepIndex(section, -1);
						setFeaturesStage(section, FEATURES_STAGE_INTRO);

						animateFeaturesOverlays(
							section,
							[
								{
									itemId: "title",
									fromState: {
										...getFeaturesSlotCenter(section, "title"),
										scale: 1,
										opacity: 1,
									},
									toState: {
										...getFeaturesCenterPoint(),
										scale: 1,
										opacity: 1,
									},
								},
								{
									itemId: "card-0",
									fromState: {
										...getFeaturesCenterPoint(),
										scale: getFeaturesCenterScale("card-0"),
										opacity: 1,
									},
									toState: {
										...getFeaturesOffscreenPoint(),
										scale: getFeaturesCenterScale("card-0") * 0.92,
										opacity: 0,
									},
								},
							],
							() => {
								syncFeaturesStableVisuals(section);
								setHomepageScrollSnapLock(null);
								featuresSequenceAnimating = false;
							},
						);
						return;
					}

					const previousStepIndex = stepIndex - 1;
					const previousStage =
						previousStepIndex >= 0 ? FEATURES_STAGE_SEQUENCE : FEATURES_STAGE_INTRO;

					setFeaturesStepIndex(section, previousStepIndex);
					setFeaturesStage(section, previousStage);
					syncFeaturesPlacedItems(section);

					animateFeaturesOverlay(
						section,
						currentStep.item,
						{
							...getFeaturesCenterPoint(),
							scale: getFeaturesCenterScale(currentStep.item),
							opacity: 1,
						},
						{
							...getFeaturesOffscreenPoint(),
							scale: getFeaturesCenterScale(currentStep.item) * 0.92,
							opacity: 0,
						},
						() => {
							syncFeaturesStableVisuals(section);
							setHomepageScrollSnapLock(null);
							featuresSequenceAnimating = false;
						},
					);
					return;
				}
			}
		}

		setHomepageScrollSnapLock(null);
		featuresSequenceAnimating = false;
	}

	function getLoreReturnY() {
		const lore = document.getElementById("lore");
		if (!lore) return 0;

		const vh = window.innerHeight;
		const rect = lore.getBoundingClientRect();
		const topDoc = Math.round(rect.top + window.scrollY);
		return Math.max(0, Math.round(topDoc + lore.offsetHeight - vh));
	}

	function getFeaturesSectionStartY(section) {
		return Math.round(section.getBoundingClientRect().top + window.scrollY);
	}

	function resetFeaturesSequence(section, stage = FEATURES_STAGE_ENTRY_PENDING) {
		setFeaturesStepIndex(section, -1);
		setFeaturesStage(section, stage);
		hideAllFeaturesOverlays(section);
		syncFeaturesStableVisuals(section);
	}

	function resolveFeaturesSequenceComplete(section, markCompleted = true) {
		if (markCompleted) {
			featuresSequenceCompletedThisLoad = true;
		}

		setFeaturesStepIndex(section, FEATURES_SEQUENCE_STEPS.length - 1);
		setFeaturesStage(section, FEATURES_STAGE_COMPLETE);
		hideAllFeaturesOverlays(section);
		syncFeaturesStableVisuals(section);
	}

	function completeFeaturesAndExitToLore(section) {
		invalidateFeaturesAnimationSession();
		featuresSequenceAnimating = false;
		featuresWheelAccumulator = 0;
		featuresTouchStartY = null;
		featuresTouchDeltaY = 0;
		setHomepageScrollSnapLock(null);
		resolveFeaturesSequenceComplete(section, true);

		window.scrollTo({
			top: getLoreReturnY(),
			behavior: "smooth",
		});
	}

	function isFeaturesAtControlPoint(section) {
		const rect = section.getBoundingClientRect();
		return (
			Math.abs(rect.top) <= FEATURES_CONTROL_TOP_TOLERANCE_PX &&
			rect.bottom > window.innerHeight * 0.5
		);
	}

	function handleFeaturesSequenceInput(section, direction) {
		if (featuresSequenceAnimating) return;

		window.scrollTo({
			top: getFeaturesSectionStartY(section),
			behavior: "instant",
		});

		const stage = getFeaturesStage(section);
		if (
			direction === "up" &&
			(stage === FEATURES_STAGE_INTRO || stage === FEATURES_STAGE_SEQUENCE)
		) {
			completeFeaturesAndExitToLore(section);
			return;
		}

		featuresSequenceAnimating = true;
		setHomepageScrollSnapLock(FEATURES_STEP_LOCK_ID);
		transitionFeaturesStep(section, direction);
	}

	let featuresScrollAbort = null;
	let featuresIntroEntryFrameId = null;
	let featuresScrollSettleTimeoutId = null;
	let featuresSequenceAnimating = false;
	let featuresWheelAccumulator = 0;
	let featuresTouchStartY = null;
	let featuresTouchDeltaY = 0;

	function initFeaturesScrollDriver() {
		const section = document.getElementById("features");
		if (!section) return;

		if (featuresScrollAbort) {
			featuresScrollAbort.abort();
			featuresScrollAbort = null;
		}

		if (featuresIntroEntryFrameId !== null) {
			window.cancelAnimationFrame(featuresIntroEntryFrameId);
			featuresIntroEntryFrameId = null;
		}

		if (featuresScrollSettleTimeoutId !== null) {
			window.clearTimeout(featuresScrollSettleTimeoutId);
			featuresScrollSettleTimeoutId = null;
		}

		featuresSequenceAnimating = false;
		featuresWheelAccumulator = 0;
		featuresTouchStartY = null;
		featuresTouchDeltaY = 0;
		featuresScrollAbort = new AbortController();
		const { signal } = featuresScrollAbort;
		let pendingEntryIntro = false;

		const abortFeaturesSequence = () => {
			pendingEntryIntro = false;

			if (featuresIntroEntryFrameId !== null) {
				window.cancelAnimationFrame(featuresIntroEntryFrameId);
				featuresIntroEntryFrameId = null;
			}

			invalidateFeaturesAnimationSession();
			featuresSequenceAnimating = false;
			featuresWheelAccumulator = 0;
			featuresTouchStartY = null;
			featuresTouchDeltaY = 0;
			setHomepageScrollSnapLock(null);
			resolveFeaturesSequenceComplete(section, true);
		};

		const reconcileFeaturesStateFromScroll = () => {
			const stage = getFeaturesStage(section);
			const atControlPoint = isFeaturesAtControlPoint(section);

			if (
				atControlPoint &&
				featuresSequenceCompletedThisLoad &&
				stage !== FEATURES_STAGE_COMPLETE &&
				!isHomepageScrollSnapLocked()
			) {
				featuresSequenceAnimating = false;
				resolveFeaturesSequenceComplete(section, false);
				return;
			}

			if (
				atControlPoint &&
				stage === FEATURES_STAGE_ENTRY_PENDING &&
				!featuresSequenceCompletedThisLoad &&
				!pendingEntryIntro &&
				!isHomepageScrollSnapLocked()
			) {
				featuresSequenceAnimating = false;
				setFeaturesStage(section, FEATURES_STAGE_INTRO);
				syncFeaturesStableVisuals(section);
				return;
			}

			if (
				atControlPoint &&
				stage === FEATURES_STAGE_INTRO_PREP &&
				!featuresSequenceCompletedThisLoad &&
				!isHomepageScrollSnapLocked()
			) {
				featuresSequenceAnimating = false;
				setFeaturesStage(section, FEATURES_STAGE_INTRO);
				syncFeaturesStableVisuals(section);
				return;
			}

			if (
				!atControlPoint &&
				!featuresSequenceCompletedThisLoad &&
				(featuresSequenceAnimating ||
					isFeaturesTransientStage(stage) ||
					(stage !== FEATURES_STAGE_ENTRY_PENDING &&
						(isHomepageScrollSnapLocked() || isFeaturesStableStage(stage))))
			) {
				abortFeaturesSequence();
			}
		};

		const onSnapLockChange = (event) => {
			const ruleId =
				event instanceof CustomEvent ? (event.detail?.ruleId ?? null) : null;

			if (ruleId === FEATURES_ENTRY_RULE_ID) {
				if (featuresSequenceCompletedThisLoad) {
					pendingEntryIntro = false;
					resolveFeaturesSequenceComplete(section, false);
					return;
				}

				pendingEntryIntro = true;
				resetFeaturesSequence(section, FEATURES_STAGE_ENTRY_PENDING);
				return;
			}

			if (!ruleId && pendingEntryIntro && getFeaturesStage(section) === FEATURES_STAGE_ENTRY_PENDING) {
				pendingEntryIntro = false;
				window.scrollTo({
					top: getFeaturesSectionStartY(section),
					behavior: "instant",
				});
				setFeaturesStage(section, FEATURES_STAGE_INTRO_PREP);
				featuresSequenceAnimating = true;
				featuresIntroEntryFrameId = window.requestAnimationFrame(() => {
					featuresIntroEntryFrameId = null;
					runFeaturesIntroEntry(section);
				});
			}
		};

		const onWheel = (event) => {
			const stage = getFeaturesStage(section);
			const shouldIntercept =
				isFeaturesAtControlPoint(section) &&
				!featuresSequenceCompletedThisLoad &&
				(stage === FEATURES_STAGE_INTRO || stage === FEATURES_STAGE_SEQUENCE);

			if (!shouldIntercept) {
				featuresWheelAccumulator = 0;
				return;
			}

			event.preventDefault();

			if (featuresSequenceAnimating) return;

			featuresWheelAccumulator += event.deltaY;
			if (Math.abs(featuresWheelAccumulator) < FEATURES_WHEEL_THRESHOLD) return;

			const direction = featuresWheelAccumulator > 0 ? "down" : "up";
			featuresWheelAccumulator = 0;
			handleFeaturesSequenceInput(section, direction);
		};

		const onTouchStart = (event) => {
			if (event.touches.length !== 1) return;
			featuresTouchStartY = event.touches[0].clientY;
			featuresTouchDeltaY = 0;
		};

		const onTouchMove = (event) => {
			if (featuresTouchStartY === null || event.touches.length !== 1) return;

			const currentY = event.touches[0].clientY;
			featuresTouchDeltaY = currentY - featuresTouchStartY;
			const stage = getFeaturesStage(section);
			const shouldPrevent =
				isFeaturesAtControlPoint(section) &&
				!featuresSequenceCompletedThisLoad &&
				(stage === FEATURES_STAGE_INTRO || stage === FEATURES_STAGE_SEQUENCE);

			if (shouldPrevent) {
				event.preventDefault();
			}
		};

		const onTouchEnd = () => {
			if (featuresTouchStartY === null) return;

			const stage = getFeaturesStage(section);
			const shouldHandle =
				isFeaturesAtControlPoint(section) &&
				!featuresSequenceCompletedThisLoad &&
				(stage === FEATURES_STAGE_INTRO || stage === FEATURES_STAGE_SEQUENCE);

			if (
				shouldHandle &&
				Math.abs(featuresTouchDeltaY) >= FEATURES_TOUCH_THRESHOLD &&
				!featuresSequenceAnimating
			) {
				handleFeaturesSequenceInput(
					section,
					featuresTouchDeltaY < 0 ? "down" : "up",
				);
			}

			featuresTouchStartY = null;
			featuresTouchDeltaY = 0;
		};

		const onResize = () => {
			if (!featuresSequenceAnimating) {
				syncFeaturesStableVisuals(section);
			}
		};

		const onScroll = () => {
			reconcileFeaturesStateFromScroll();

			if (featuresScrollSettleTimeoutId !== null) {
				window.clearTimeout(featuresScrollSettleTimeoutId);
			}

			featuresScrollSettleTimeoutId = window.setTimeout(() => {
				featuresScrollSettleTimeoutId = null;
				reconcileFeaturesStateFromScroll();
			}, 90);
		};

		document.addEventListener("snowbound:scroll-snap-lock-change", onSnapLockChange, {
			signal,
		});
		window.addEventListener("scroll", onScroll, { passive: true, signal });
		window.addEventListener("wheel", onWheel, { passive: false, signal });
		window.addEventListener("touchstart", onTouchStart, { passive: true, signal });
		window.addEventListener("touchmove", onTouchMove, { passive: false, signal });
		window.addEventListener("touchend", onTouchEnd, { passive: true, signal });
		window.addEventListener("resize", onResize, { passive: true, signal });
		reconcileFeaturesStateFromScroll();
	}

	function initFeaturesSection() {
		const section = document.getElementById("features");
		if (!section) return;

		if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
			resolveFeaturesSequenceComplete(section, true);
			return;
		}

		if (featuresSequenceCompletedThisLoad) {
			resolveFeaturesSequenceComplete(section, false);
			initFeaturesScrollDriver();
			return;
		}

		resetFeaturesSequence(section, FEATURES_STAGE_ENTRY_PENDING);
		initFeaturesScrollDriver();
	}

	initFeaturesSection();
	document.addEventListener("astro:page-load", initFeaturesSection);
</script>

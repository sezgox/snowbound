---
const cards = [
	{
		title: ["CHANGING", "BOARD"],
		body: "Break the ice and reveal a new map every game",
	},
	{
		title: ["HIGH PLAYER", "INTERACTION"],
		body: "Steal, block and outplay your rivals at every turn.",
	},
	{
		title: ["RISK VS REWARD"],
		body: "Push your luck... or play it safe and lose the race.",
	},
	{
		title: ["2 PATHS TO", "VICTORIES"],
		body: "You don't need to follow everyone else's path.",
	},
] as const;

const cardCount = cards.length;
const trackVh = Math.min(440, Math.max(300, 72 * cardCount + 140));
---

<section
	id="features"
	class="features-scroll-track relative w-full scroll-mt-0"
	style={`min-height: ${trackVh}vh; background-image: url('/images/figma/hex-board.png'); background-size: cover; background-position: center; background-repeat: no-repeat; background-attachment: fixed;`}
	aria-labelledby="features-heading"
	data-features-scroll
	data-features-stage="content"
	data-page-snap="start"
>
	<div class="pointer-events-none absolute inset-0 z-0 bg-white/[0.66]" aria-hidden="true" />

	<div
		class="features-sticky-wrap sticky top-0 z-10 flex min-h-[100dvh] w-full flex-col items-center gap-9 overflow-hidden py-10 md:min-h-[1012px] md:gap-[35px]"
	>
		<p
			class="features-intro-title font-display text-shadow-outline text-shadow-white pointer-events-none fixed left-1/2 top-1/2 z-40 text-center tracking-wide text-[#112d57]"
			aria-hidden="true"
		>
			WHAT MAKES IT UNIQUE
		</p>

		<div class="section-inner relative z-10 flex w-full flex-col items-center gap-16 px-4 md:gap-[70px]">
			<h2
				id="features-heading"
				class="features-title-wrap font-display text-shadow-outline text-shadow-white text-center tracking-wide text-[#112d57] drop-shadow-[0_4px_6px_rgba(0,0,0,0.25)]"
			>
				WHAT MAKES IT UNIQUE
			</h2>
			<div
				data-features-cards
				class="features-cards-row flex w-full flex-wrap justify-center gap-6 text-center md:gap-x-6 md:gap-y-0"
			>
				{
					cards.map((c, i) => (
						<div class="features-card-slot flex min-h-[255px] w-[min(100%,229px)] shrink-0 justify-center">
							<div
								data-features-card
								data-card-index={i}
								class="features-reveal-card relative flex h-auto min-h-[255px] w-full max-w-full flex-col items-center justify-center gap-10 rounded-[10px] border border-[#77abbd] bg-white px-5 py-10"
							>
								<div class="font-tillana w-full text-2xl font-bold leading-8 tracking-wide text-black">
									{c.title.map((line) => (
										<p class="mb-0 leading-8">{line}</p>
									))}
								</div>
								<p class="font-nunito w-full text-base leading-6 tracking-wide text-[#5c5c5c]">
									{c.body}
								</p>
							</div>
						</div>
					))
				}
			</div>
		</div>

		<div class="section-inner relative z-10 mt-2 px-4">
			<div
				class="features-video-block h-[200px] w-full shrink-0 bg-[#8b8686] md:h-[400px]"
				aria-hidden="true"
			>
			</div>
		</div>

		<p
			class="features-scroll-hint pointer-events-none fixed bottom-8 left-1/2 z-40 md:bottom-10"
			aria-hidden="true"
			data-features-scroll-hint
			hidden
		>
			<span class="features-scroll-hint__pill font-nunito">
				<span class="features-scroll-hint__icon" aria-hidden="true">&darr;</span>
				Keep scrolling
			</span>
		</p>

		<div class="features-cta-wrap relative z-10 mt-4 flex w-full justify-center px-3 sm:px-4">
			<button
				type="button"
				data-open-waitlist
				class="font-tillana flex w-full max-w-[min(100%,778px)] items-center justify-center rounded-[50px] bg-snowbound-primary px-4 py-2.5 text-lg leading-none tracking-tight text-white shadow-[0_4px_31px_rgba(0,0,0,0.15)] transition hover:bg-[#0270c2] max-md:min-h-[56px] max-md:whitespace-nowrap md:h-[78px] md:px-[70px] md:py-0 md:text-[48px] md:leading-8 md:tracking-[0.1px]"
			>
				JOIN THE WAITLIST
			</button>
		</div>
	</div>
</section>

<noscript>
	<style>
		#features .features-intro-title {
			display: none !important;
		}
		#features .features-title-wrap {
			opacity: 1 !important;
			transform: none !important;
		}
		[data-features-card] {
			opacity: 1 !important;
			transform: none !important;
			transition: none !important;
		}
		.features-scroll-hint {
			display: none !important;
		}
		#features .features-cards-row,
		#features .features-video-block,
		#features .features-cta-wrap {
			opacity: 1 !important;
			visibility: visible !important;
			pointer-events: auto !important;
		}
	</style>
</noscript>

<style>
	#features[data-features-scroll] {
		--features-p: 0;
		--features-intro-target-x: 50vw;
		--features-intro-target-y: 50vh;
	}

	.features-title-wrap {
		width: 100%;
		margin: 0;
		padding: 0.75rem 1rem;
		font-size: clamp(1.5rem, 4vw, 4rem);
		line-height: 1.1;
		opacity: 1;
		transform: none;
		transition: opacity 0.28s ease;
		will-change: opacity;
	}

	.features-intro-title {
		width: min(92vw, 920px);
		margin: 0;
		padding: 0.75rem 1rem;
		font-size: clamp(2rem, 7.5vw, 4rem);
		line-height: 1.05;
		opacity: 0;
		transform: translate3d(-50%, calc(-50% + 18vh), 0);
		transition:
			left 0.75s cubic-bezier(0.22, 1, 0.36, 1),
			top 0.75s cubic-bezier(0.22, 1, 0.36, 1),
			transform 0.75s cubic-bezier(0.22, 1, 0.36, 1),
			opacity 0.35s ease;
		will-change: left, top, transform, opacity;
	}

	#features[data-features-stage="intro"] .features-intro-title {
		opacity: 1;
		transform: translate3d(-50%, -50%, 0);
	}

	#features[data-features-stage="transition-down"] .features-intro-title {
		opacity: 1;
		left: var(--features-intro-target-x);
		top: var(--features-intro-target-y);
		transform: translate3d(-50%, -50%, 0);
	}

	#features[data-features-stage="exit-up"] .features-intro-title {
		opacity: 0;
		transform: translate3d(-50%, calc(-50% + 22vh), 0);
	}

	#features[data-features-stage="content"] .features-intro-title {
		opacity: 0;
		left: var(--features-intro-target-x);
		top: var(--features-intro-target-y);
		transform: translate3d(-50%, -50%, 0);
	}

	#features[data-features-stage="intro-prep"] .features-intro-title,
	#features[data-features-stage="entry-pending"] .features-intro-title {
		opacity: 0;
	}

	#features[data-features-stage="intro-prep"] .features-title-wrap,
	#features[data-features-stage="entry-pending"] .features-title-wrap,
	#features[data-features-stage="intro"] .features-title-wrap,
	#features[data-features-stage="transition-down"] .features-title-wrap,
	#features[data-features-stage="exit-up"] .features-title-wrap {
		opacity: 0;
	}

	#features[data-features-stage="content"][data-features-viewport="below"] .features-title-wrap {
		opacity: 0;
	}

	#features[data-features-stage="entry-pending"] .features-cards-row,
	#features[data-features-stage="entry-pending"] .features-video-block,
	#features[data-features-stage="entry-pending"] .features-cta-wrap,
	#features[data-features-stage="intro-prep"] .features-cards-row,
	#features[data-features-stage="intro-prep"] .features-video-block,
	#features[data-features-stage="intro-prep"] .features-cta-wrap,
	#features[data-features-stage="intro"] .features-cards-row,
	#features[data-features-stage="intro"] .features-video-block,
	#features[data-features-stage="intro"] .features-cta-wrap,
	#features[data-features-stage="transition-down"] .features-cards-row,
	#features[data-features-stage="transition-down"] .features-video-block,
	#features[data-features-stage="transition-down"] .features-cta-wrap,
	#features[data-features-stage="exit-up"] .features-cards-row,
	#features[data-features-stage="exit-up"] .features-video-block,
	#features[data-features-stage="exit-up"] .features-cta-wrap {
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
	}

	#features[data-features-stage="content"] .features-cards-row {
		opacity: clamp(0, calc((var(--features-p) - 0.14) / 0.06), 1);
		visibility: visible;
		pointer-events: auto;
	}

	#features[data-features-stage="content"] .features-reveal-card {
		--f: var(--card-focus, 0);
		opacity: calc(0.2 + 0.8 * min(1, var(--f) * 2.2));
		transform: translate3d(
				0,
				calc((1 - min(1, var(--f) * 1.4)) * clamp(2rem, 10vw, 5rem)),
				0
			)
			scale(calc(1 + var(--f) * 1.05));
		z-index: calc(10 + var(--f) * 25);
		box-shadow:
			0 calc(var(--f) * 24px) calc(var(--f) * 56px) rgba(17, 45, 87, 0.22),
			0 calc(var(--f) * 8px) calc(var(--f) * 20px) rgba(0, 0, 0, 0.12);
		transition: none;
		will-change: transform, opacity;
	}

	#features[data-features-stage="content"] .features-video-block,
	#features[data-features-stage="content"] .features-cta-wrap {
		opacity: clamp(0, calc((var(--features-p) - 0.72) / 0.18), 1);
		visibility: visible;
		pointer-events: auto;
		transition: none;
	}

	.features-scroll-hint {
		transform: translateX(-50%);
		opacity: 0;
		visibility: hidden;
		transition:
			opacity 0.35s ease,
			visibility 0s linear 0.35s;
	}

	#features[data-features-stage="intro"] .features-scroll-hint {
		opacity: 1;
		visibility: visible;
		transition-delay: 0s;
	}

	#features[data-features-stage="entry-pending"] .features-scroll-hint,
	#features[data-features-stage="intro-prep"] .features-scroll-hint,
	#features[data-features-stage="transition-down"] .features-scroll-hint,
	#features[data-features-stage="exit-up"] .features-scroll-hint,
	#features[data-features-stage="content"] .features-scroll-hint {
		opacity: 0;
		visibility: hidden;
	}

	.features-scroll-hint__pill {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 0.75rem 1.35rem;
		border-radius: 9999px;
		background: var(--color-snowbound-primary);
		color: #fff;
		font-size: clamp(0.8rem, 2.4vw, 1rem);
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		border: 2px solid rgba(255, 255, 255, 0.4);
		box-shadow:
			0 10px 32px rgba(2, 133, 228, 0.45),
			0 4px 14px rgba(0, 0, 0, 0.18),
			inset 0 1px 0 rgba(255, 255, 255, 0.2);
		text-shadow: 0 1px 0 rgba(0, 0, 0, 0.12);
		white-space: nowrap;
	}

	.features-scroll-hint__icon {
		font-size: 1.1em;
		line-height: 1;
		animation: features-hint-bounce 1.1s ease-in-out infinite;
	}

	@keyframes features-hint-bounce {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(4px);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		#features .features-intro-title {
			display: none;
		}
		#features .features-title-wrap {
			opacity: 1;
		}
		#features .features-reveal-card {
			opacity: 1;
			transform: none;
			box-shadow: none;
			will-change: auto;
		}
		#features .features-cards-row,
		#features .features-video-block,
		#features .features-cta-wrap {
			opacity: 1;
			visibility: visible;
			pointer-events: auto;
		}
		.features-scroll-hint {
			display: none;
		}
	}
</style>

<script is:inline>
	const FEATURES_STAGE_ENTRY_PENDING = "entry-pending";
	const FEATURES_STAGE_INTRO_PREP = "intro-prep";
	const FEATURES_STAGE_INTRO = "intro";
	const FEATURES_STAGE_TRANSITION_DOWN = "transition-down";
	const FEATURES_STAGE_EXIT_UP = "exit-up";
	const FEATURES_STAGE_CONTENT = "content";
	const FEATURES_ENTRY_RULE_ID = "lore-to-features";
	const FEATURES_INTERNAL_SNAP_LOCK_ID = "features-intro-to-content";
	const FEATURES_EXIT_TO_LORE_LOCK_ID = "features-intro-back-to-lore";
	const FEATURES_INTERNAL_SNAP_PROGRESS = 0.24;
	const FEATURES_INTERNAL_SNAP_TRIGGER_OFFSET_PX = 4;
	const FEATURES_LOCK_DURATION_MS = 750;

	function isHomepageScrollSnapLocked() {
		return Boolean(document.documentElement.dataset.scrollSnapLock);
	}

	function setHomepageScrollSnapLock(ruleId) {
		const root = document.documentElement;

		if (ruleId) {
			root.dataset.scrollSnapLock = ruleId;
		} else {
			delete root.dataset.scrollSnapLock;
		}

		document.dispatchEvent(
			new CustomEvent("snowbound:scroll-snap-lock-change", {
				detail: { ruleId },
			}),
		);
	}

	function getFeaturesStage(section) {
		return section.dataset.featuresStage ?? FEATURES_STAGE_CONTENT;
	}

	function resetFeaturesCardFocus(section) {
		section.querySelectorAll("[data-features-card]").forEach((el) => {
			el.style.setProperty("--card-focus", "0");
		});
	}

	function syncFeaturesFlowTitleVisibility(section) {
		const flowTitle = section.querySelector(".features-title-wrap");
		if (!(flowTitle instanceof HTMLElement)) return;

		const stage = getFeaturesStage(section);
		const viewportState = section.dataset.featuresViewport ?? "entered";
		const shouldHide =
			stage !== FEATURES_STAGE_CONTENT || viewportState === "below";

		flowTitle.style.opacity = shouldHide ? "0" : "1";
		flowTitle.style.visibility = shouldHide ? "hidden" : "visible";
	}

function syncFeaturesIntroTitleVisual(section) {
	const introTitle = section.querySelector(".features-intro-title");
	if (!(introTitle instanceof HTMLElement)) return;

		const stage = getFeaturesStage(section);
		const offscreenTransform = "translate3d(-50%, calc(-50% + 18vh), 0)";
		const exitTransform = "translate3d(-50%, calc(-50% + 22vh), 0)";
		const centeredTransform = "translate3d(-50%, -50%, 0)";

		if (stage === FEATURES_STAGE_TRANSITION_DOWN || stage === FEATURES_STAGE_CONTENT) {
			introTitle.style.left = "var(--features-intro-target-x)";
			introTitle.style.top = "var(--features-intro-target-y)";
		} else {
			introTitle.style.left = "50%";
			introTitle.style.top = "50%";
		}

		if (stage === FEATURES_STAGE_INTRO) {
			introTitle.style.opacity = "1";
			introTitle.style.transform = centeredTransform;
			return;
		}

		if (stage === FEATURES_STAGE_TRANSITION_DOWN) {
			introTitle.style.opacity = "1";
			introTitle.style.transform = centeredTransform;
			return;
		}

		if (stage === FEATURES_STAGE_EXIT_UP) {
			introTitle.style.opacity = "0";
			introTitle.style.transform = exitTransform;
			return;
		}

		if (stage === FEATURES_STAGE_CONTENT) {
			introTitle.style.opacity = "0";
			introTitle.style.transform = centeredTransform;
			return;
		}

	introTitle.style.opacity = "0";
	introTitle.style.transform = offscreenTransform;
}

function playFeaturesIntroEntry(section) {
	const introTitle = section.querySelector(".features-intro-title");
	if (!(introTitle instanceof HTMLElement)) return;

	if (featuresIntroAnimation) {
		featuresIntroAnimation.cancel();
		featuresIntroAnimation = null;
	}

	const offscreenTransform = "translate3d(-50%, calc(-50% + 18vh), 0)";
	const centeredTransform = "translate3d(-50%, -50%, 0)";

	introTitle.hidden = false;
	introTitle.style.left = "50%";
	introTitle.style.top = "50%";
	introTitle.style.opacity = "0";
	introTitle.style.transform = offscreenTransform;
	void introTitle.offsetHeight;

	featuresIntroAnimation = introTitle.animate(
		[
			{ opacity: 0, transform: offscreenTransform },
			{ opacity: 1, transform: centeredTransform },
		],
		{
			duration: FEATURES_LOCK_DURATION_MS,
			easing: "cubic-bezier(0.22, 1, 0.36, 1)",
			fill: "forwards",
		},
	);

	introTitle.style.opacity = "1";
	introTitle.style.transform = centeredTransform;

	featuresIntroAnimation.onfinish = () => {
		featuresIntroAnimation = null;
	};
	featuresIntroAnimation.oncancel = () => {
		featuresIntroAnimation = null;
	};
}

	function setFeaturesStage(section, stage) {
		section.dataset.featuresStage = stage;

		if (stage !== FEATURES_STAGE_INTRO && featuresIntroAnimation) {
			featuresIntroAnimation.cancel();
			featuresIntroAnimation = null;
		}

		const scrollHint = section.querySelector("[data-features-scroll-hint]");
		if (scrollHint instanceof HTMLElement) {
			scrollHint.hidden = stage !== FEATURES_STAGE_INTRO;
		}

		syncFeaturesIntroTitleVisual(section);
		syncFeaturesFlowTitleVisibility(section);

		if (stage !== FEATURES_STAGE_CONTENT) {
			section.style.setProperty("--features-p", "0");
			resetFeaturesCardFocus(section);
		}
	}

	function getFeaturesSectionStartY(section) {
		return Math.round(section.getBoundingClientRect().top + window.scrollY);
	}

	function getFeaturesScrollProgress(section) {
		const vh = window.innerHeight;
		const h = section.offsetHeight;
		const range = Math.max(0, h - vh);
		if (range <= 0) return 1;
		const top = section.getBoundingClientRect().top;
		const scrolled = -top;
		return Math.min(1, Math.max(0, scrolled / range));
	}

	function syncFeaturesViewportState(section) {
		section.dataset.featuresViewport =
			section.getBoundingClientRect().top > 0 ? "below" : "entered";
		syncFeaturesFlowTitleVisibility(section);
	}

	function getFeaturesInternalSnapY(section) {
		const range = Math.max(0, section.offsetHeight - window.innerHeight);
		return Math.max(
			0,
			Math.round(
				getFeaturesSectionStartY(section) + range * FEATURES_INTERNAL_SNAP_PROGRESS,
			),
		);
	}

	function getLoreReturnY() {
		const lore = document.getElementById("lore");
		if (!lore) return 0;

		const vh = window.innerHeight;
		const rect = lore.getBoundingClientRect();
		const topDoc = Math.round(rect.top + window.scrollY);
		return Math.max(0, Math.round(topDoc + lore.offsetHeight - vh));
	}

	function setIntroTargetPosition(section) {
		const title = section.querySelector(".features-title-wrap");
		if (!title) return;

		const rect = title.getBoundingClientRect();
		const centerX = rect.left + rect.width / 2;
		const centerY = rect.top + rect.height / 2;

		section.style.setProperty("--features-intro-target-x", `${centerX}px`);
		section.style.setProperty("--features-intro-target-y", `${centerY}px`);
	}

	function smoothstep(edge0, edge1, x) {
		const t = Math.min(1, Math.max(0, (x - edge0) / (edge1 - edge0)));
		return t * t * (3 - 2 * t);
	}

	function updateFeaturesScrollDriven() {
		const section = document.getElementById("features");
		if (!section || !section.hasAttribute("data-features-scroll")) return;

		syncFeaturesViewportState(section);

		if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
			setFeaturesStage(section, FEATURES_STAGE_CONTENT);
			section.style.setProperty("--features-p", "1");
			resetFeaturesCardFocus(section);
			return;
		}

		if (getFeaturesStage(section) !== FEATURES_STAGE_CONTENT) {
			section.style.setProperty("--features-p", "0");
			resetFeaturesCardFocus(section);
			return;
		}

		if (isHomepageScrollSnapLocked()) {
			return;
		}

		const p = getFeaturesScrollProgress(section);
		section.style.setProperty("--features-p", String(p));

		const cards = section.querySelectorAll("[data-features-card]");
		const n = cards.length;
		if (n < 1) return;

		const startCards = 0.16;
		const endCards = 0.68;
		const span = (endCards - startCards) / n;

		cards.forEach((card, i) => {
			const a = startCards + i * span;
			const b = a + span;
			const mid = (a + b) / 2;
			const half = span * 0.42;
			let focus = 0;
			if (p >= a && p <= b) {
				const dist = Math.abs(p - mid);
				focus = Math.max(0, 1 - dist / half);
				focus = smoothstep(0, 1, focus);
			}
			card.style.setProperty("--card-focus", String(focus));
		});
	}

let featuresScrollAbort = null;
let featuresStageTimeoutId = null;
let featuresIntroEntryFrameId = null;
let featuresIntroAnimation = null;

	function initFeaturesScrollDriver() {
		const section = document.getElementById("features");
		if (!section) return;

		if (featuresScrollAbort) {
			featuresScrollAbort.abort();
			featuresScrollAbort = null;
		}

		if (featuresStageTimeoutId !== null) {
			window.clearTimeout(featuresStageTimeoutId);
			featuresStageTimeoutId = null;
		}

		if (featuresIntroEntryFrameId !== null) {
			window.cancelAnimationFrame(featuresIntroEntryFrameId);
			featuresIntroEntryFrameId = null;
		}

		if (featuresIntroAnimation) {
			featuresIntroAnimation.cancel();
			featuresIntroAnimation = null;
		}

		featuresScrollAbort = new AbortController();
		const { signal } = featuresScrollAbort;

		let lastScrollY = window.scrollY;
		let ticking = false;
		let pendingEntryIntro = false;

		const queueUpdate = () => {
			if (ticking) return;
			ticking = true;
			requestAnimationFrame(() => {
				ticking = false;
				updateFeaturesScrollDriven();
			});
		};

		const finishTransition = (nextStage) => {
			featuresStageTimeoutId = null;
			setFeaturesStage(section, nextStage);
			setHomepageScrollSnapLock(null);
			updateFeaturesScrollDriven();
			lastScrollY = window.scrollY;
		};

		const runInternalSnapDown = () => {
			setIntroTargetPosition(section);
			setFeaturesStage(section, FEATURES_STAGE_TRANSITION_DOWN);
			setHomepageScrollSnapLock(FEATURES_INTERNAL_SNAP_LOCK_ID);
			window.scrollTo({
				top: getFeaturesInternalSnapY(section),
				behavior: "smooth",
			});

			if (featuresStageTimeoutId !== null) {
				window.clearTimeout(featuresStageTimeoutId);
			}

			featuresStageTimeoutId = window.setTimeout(() => {
				finishTransition(FEATURES_STAGE_CONTENT);
			}, FEATURES_LOCK_DURATION_MS);
		};

		const runExitToLore = () => {
			setFeaturesStage(section, FEATURES_STAGE_EXIT_UP);
			setHomepageScrollSnapLock(FEATURES_EXIT_TO_LORE_LOCK_ID);
			window.scrollTo({
				top: getLoreReturnY(),
				behavior: "smooth",
			});

			if (featuresStageTimeoutId !== null) {
				window.clearTimeout(featuresStageTimeoutId);
			}

			featuresStageTimeoutId = window.setTimeout(() => {
				finishTransition(FEATURES_STAGE_CONTENT);
			}, FEATURES_LOCK_DURATION_MS);
		};

		const tryHandleIntroScroll = () => {
			if (getFeaturesStage(section) !== FEATURES_STAGE_INTRO) return;
			if (isHomepageScrollSnapLocked()) return;

			const scrollY = window.scrollY;
			const goingDown = scrollY > lastScrollY + 4;
			const goingUp = scrollY < lastScrollY - 4;
			const sectionStartY = getFeaturesSectionStartY(section);

			if (goingDown && scrollY > sectionStartY + FEATURES_INTERNAL_SNAP_TRIGGER_OFFSET_PX) {
				runInternalSnapDown();
				return;
			}

			if (goingUp) {
				runExitToLore();
			}
		};

		function onScrollOrResize() {
			tryHandleIntroScroll();
			queueUpdate();
			lastScrollY = window.scrollY;
		}

		const onSnapLockChange = (event) => {
			const ruleId =
				event instanceof CustomEvent ? (event.detail?.ruleId ?? null) : null;

			if (ruleId === FEATURES_ENTRY_RULE_ID) {
				pendingEntryIntro = true;

				if (featuresIntroEntryFrameId !== null) {
					window.cancelAnimationFrame(featuresIntroEntryFrameId);
					featuresIntroEntryFrameId = null;
				}

				setFeaturesStage(section, FEATURES_STAGE_ENTRY_PENDING);
			} else if (!ruleId && pendingEntryIntro) {
				pendingEntryIntro = false;
				setIntroTargetPosition(section);

				setFeaturesStage(section, FEATURES_STAGE_INTRO_PREP);
				const introTitle = section.querySelector(".features-intro-title");
				if (introTitle instanceof HTMLElement) void introTitle.offsetHeight;
				featuresIntroEntryFrameId = window.requestAnimationFrame(() => {
					featuresIntroEntryFrameId = null;
					setFeaturesStage(section, FEATURES_STAGE_INTRO);
					playFeaturesIntroEntry(section);
				});
			}

			if (!isHomepageScrollSnapLocked()) {
				queueUpdate();
			}

			lastScrollY = window.scrollY;
		};

		setIntroTargetPosition(section);
		syncFeaturesViewportState(section);
		updateFeaturesScrollDriven();
		window.addEventListener("scroll", onScrollOrResize, { passive: true, signal });
		window.addEventListener("resize", onScrollOrResize, { passive: true, signal });
		document.addEventListener("snowbound:scroll-snap-lock-change", onSnapLockChange, {
			signal,
		});
	}

	function initFeaturesSection() {
		const section = document.getElementById("features");
		if (!section) return;

		if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
			setFeaturesStage(section, FEATURES_STAGE_CONTENT);
			section.style.setProperty("--features-p", "1");
			resetFeaturesCardFocus(section);
			return;
		}

		setFeaturesStage(section, FEATURES_STAGE_CONTENT);
		initFeaturesScrollDriver();
	}

	initFeaturesSection();
	document.addEventListener("astro:page-load", initFeaturesSection);
</script>

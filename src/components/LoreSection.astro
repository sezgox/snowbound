---
import { assets } from "../data/figmaAssets";
import type { Messages } from "../i18n";

interface Props {
	messages: Messages["lore"];
}

const { messages } = Astro.props;
---

<section
	id="lore"
	class="lore-section relative mb-[-2px] min-h-[75vh] w-full content-center py-6 overflow-x-hidden"
	aria-labelledby="lore-heading"
	style="background-image: linear-gradient(180deg, var(--color-snowbound-cream) 0%, 
	rgba(250, 249, 242, 0) 10%), url('/images/figma/pattern-ice.png'); 
	background-position: center, center; 
	background-repeat: no-repeat, no-repeat;
	"
>
	<div
		class="section-inner flex min-w-0 flex-col items-center gap-4 px-2 md:flex-row md:items-stretch md:justify-between"
	>
		<div class="flex min-w-0 flex-col gap-5 md:flex-1 md:self-stretch md:gap-6">
			<h2
				id="lore-heading"
				data-lore-reveal
				class="lore-reveal-block lore-reveal-block--ltr font-display max-w-[557px] text-4xl font-normal leading-tight tracking-[0.2px] text-snowbound-secondary md:text-[64px] md:leading-[48px]"
			>
				{messages.heading}
			</h2>
			<div
				data-lore-reveal
				class="lore-reveal-block lore-reveal-block--paragraph font-roboto flex w-full max-w-[557px] flex-col gap-4 p-2.5 text-[20px] font-normal leading-7 tracking-[0.2px] text-black md:flex-1 md:justify-between md:p-[10px] md:leading-[28px]"
			>
				<p class="md:leading-[28px]">{messages.paragraphs[0]}</p>
				<p class="md:leading-[28px]">{messages.paragraphs[1]}</p>
				<p class="md:leading-[28px]">{messages.paragraphs[2]}</p>
			</div>
		</div>

		<img
			src={assets.tree}
			alt={messages.imageAlt}
			data-lore-reveal
			class="lore-reveal-block lore-reveal-block--image w-full shrink-0 max-w-[min(340px,85vw)] lg:max-w-[380px]"
		/>
	</div>
</section>

<noscript>
	<style>
		[data-lore-reveal] {
			opacity: 1 !important;
			transform: none !important;
		}
	</style>
</noscript>

<style>
	.lore-section {
		background-size: 100% 100%;
	}

	@media (max-width: 768px) {
		.lore-section {
			background-size: cover;
		}
	}

	#lore .lore-reveal-block {
		opacity: 0;
		transition:
			opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1),
			transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
		will-change: opacity, transform;
	}

	#lore .lore-reveal-block:not(.is-in-view) {
		transform: translate3d(clamp(3.25rem, 6vw, 5.25rem), 0, 0);
	}

	#lore .lore-reveal-block.lore-reveal-block--ltr:not(.is-in-view) {
		transform: translate3d(calc(-1 * clamp(3.25rem, 6vw, 5.25rem)), 0, 0);
	}

	@media (min-width: 1024px) {
		#lore .lore-reveal-block.lore-reveal-block--paragraph:not(.is-in-view) {
			transform: translate3d(calc(-1 * clamp(3.25rem, 6vw, 5.25rem)), 0, 0);
		}
	}

	@media (max-width: 1023px) {
		#lore .lore-reveal-block.lore-reveal-block--image:not(.is-in-view) {
			transform: translate3d(calc(-1 * clamp(3.25rem, 6vw, 5.25rem)), 0, 0);
		}
	}

	#lore .lore-reveal-block.is-in-view {
		opacity: 1;
		transform: translate3d(0, 0, 0);
	}

	@media (prefers-reduced-motion: reduce) {
		#lore .lore-reveal-block {
			opacity: 1;
			transform: none;
			transition: none;
			will-change: auto;
		}
	}
</style>

<script is:inline>
	function loreHeightVisibleRatio(el, marginBottomRatio) {
		const rect = el.getBoundingClientRect();
		const vh = window.innerHeight;
		const m = marginBottomRatio ?? 0;
		const viewportBottom = vh * (1 - m);
		const visibleTop = Math.max(0, rect.top);
		const visibleBottom = Math.min(viewportBottom, rect.bottom);
		const visibleHeight = Math.max(0, visibleBottom - visibleTop);
		if (rect.height <= 0) return 0;
		return visibleHeight / rect.height;
	}

	function initLoreReveal() {
		const blocks = document.querySelectorAll("[data-lore-reveal]");
		if (!blocks.length) return;

		const minRatio = 0.8;
		const rootMarginBottomPct = 0;

		const markIfNeeded = (el) => {
			if (el.classList.contains("is-in-view")) return;
			if (
				loreHeightVisibleRatio(el, rootMarginBottomPct / 100) >=
				minRatio - 0.02
			) {
				el.classList.add("is-in-view");
			}
		};

		const observeOne = (el) => {
			markIfNeeded(el);
			if (el.classList.contains("is-in-view")) return;

			if (!("IntersectionObserver" in window)) {
				el.classList.add("is-in-view");
				return;
			}

			const io = new IntersectionObserver(
				(entries) => {
					for (const e of entries) {
						if (e.intersectionRatio >= minRatio) {
							e.target.classList.add("is-in-view");
							io.unobserve(e.target);
							break;
						}
					}
				},
				{
					threshold: [0, 0.25, 0.5, 0.75, 0.8, 0.9, 1],
					rootMargin: `0px 0px -${rootMarginBottomPct}% 0px`,
				},
			);
			io.observe(el);
		};

		for (const el of blocks) {
			observeOne(el);
		}
	}

	initLoreReveal();
	document.addEventListener("astro:page-load", initLoreReveal);
</script>

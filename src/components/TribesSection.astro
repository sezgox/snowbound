---
import { assets } from "../data/figmaAssets";
import { tribeSlides, tribesSharedParchment } from "../data/tribes";

const n = tribeSlides.length;
---

<section
	id="tribes"
	class="w-full scroll-mt-24 border-8 border-solid border-[#faf9f2] md:border-[25px] overflow-hidden"
	aria-labelledby="tribes-heading"
>
	<div
		class="relative w-full"
		data-tribes-root
		data-tribes-count={n}
	>
		<h2 id="tribes-heading" class="sr-only">The Inuit tribes</h2>

		<!-- All slides stacked in the same grid cell via CSS grid-area -->
		<div
			class="tribes-slides-container touch-pan-y"
			data-tribes-slides
			role="region"
			aria-label="Tribe slides"
			tabindex="0"
		>
			{
				tribeSlides.map((slide, i) => (
					<article
						class={`tribes-slide${i === 0 ? " is-active" : ""} relative overflow-hidden py-6 md:py-0`}
						style={
							slide.background.kind === "gradient"
								? `background-image: ${slide.background.css};`
								: `background-color: ${slide.background.hex};`
						}
						aria-roledescription="slide"
						aria-label={`Tribe ${i + 1} of ${n}`}
						aria-hidden={i === 0 ? "false" : "true"}
						data-tribes-slide-index={i}
					>
						<div class="section-inner relative z-10 flex flex-col items-center px-4 md:px-8">
							<div class="mb-6 flex w-full max-w-[800px] justify-center py-5">
								{slide.background.kind === "gradient" ? (
									<p class="font-display text-center text-4xl tracking-[0.2px] text-[#112d57] md:text-[64px] md:leading-[64px]">
										<span class="md:whitespace-nowrap">{`THE INUIT `}</span>
										<span class="md:whitespace-nowrap">TRIBES</span>
									</p>
								) : (
									<p class="font-display text-center text-4xl tracking-[0.2px] text-[#112d57] md:text-[64px] md:leading-[64px] md:whitespace-nowrap">
										THE INUIT TRIBES
									</p>
								)}
							</div>

							<div class="relative flex w-full max-w-[756px] flex-col items-center gap-6 md:min-h-[320px] md:flex-row md:items-center md:justify-center md:gap-0">
								<div class="flex w-full shrink-0 justify-center overflow-hidden md:w-[322px] md:max-w-[322px]">
									<div class="relative mx-auto h-[min(360px,55vh)] w-full max-w-[280px] md:h-[402px] md:max-w-[253px]">
										<img
											src={slide.character}
											alt=""
											class="pointer-events-none absolute inset-0 size-full max-w-none object-contain object-bottom"
										/>
									</div>
								</div>

								<div class="relative flex min-h-[260px] w-full min-w-0 flex-1 items-center justify-center overflow-hidden md:min-h-[326px] md:max-w-[529px]">
									<div
										class="pointer-events-none absolute inset-0 flex items-center justify-center overflow-hidden"
										aria-hidden="true"
									>
										<div class="-rotate-90 scale-[0.72] sm:scale-[0.85] md:scale-100">
											<div class="relative h-[528.923px] w-[325.588px] max-w-none">
												<div class="absolute inset-0 overflow-hidden">
													<img
														src={slide.parchment}
														alt=""
														class="absolute left-[-10%] top-0 h-full w-[120%] max-w-none"
													/>
												</div>
											</div>
										</div>
									</div>
									<div class="relative z-10 flex w-full max-w-[415px] flex-col items-center gap-4 px-6 text-center text-black md:px-14">
										<h3 class="font-tillana text-[clamp(2rem,5vw,3rem)] font-medium leading-tight tracking-[0.1px] text-black md:text-[48px] md:leading-[32px]">
											{slide.name}
										</h3>
										<div class="font-nunito w-full space-y-3 text-lg leading-6 tracking-[0.2px] text-black md:text-xl md:leading-6">
											{slide.lines.map((line) => (
												<p class="mb-0">{line}</p>
											))}
										</div>
									</div>
								</div>
							</div>

							<div class="mt-3 flex w-full max-w-[256px] justify-center md:mt-4">
								<img
									src={slide.border}
									alt=""
									class="pointer-events-none h-auto w-full max-w-[256px] object-contain"
								/>
							</div>
						</div>
					</article>
				))
			}
		</div>

		<button
			type="button"
			class="absolute left-1 top-[42%] z-30 flex h-[52px] w-[36px] -translate-y-1/2 cursor-pointer items-center justify-center md:left-[max(0.75rem,calc(50%-min(600px,35vw)-3rem))] md:h-[62px] md:w-[34px]"
			data-tribes-prev
			aria-label="Previous tribe"
		>
			<span
				class="flex size-full items-center justify-center overflow-hidden [container-type:size]"
			>
				<span class="flex h-[100cqw] w-[100cqh] rotate-90 items-center justify-center">
					<span class="relative block size-full overflow-hidden">
						<img
							src={assets.tribesChevron}
							alt=""
							class="pointer-events-none absolute left-0 top-[-41%] h-[182%] w-full max-w-none object-cover"
						/>
					</span>
				</span>
			</span>
		</button>

		<button
			type="button"
			class="absolute right-1 top-[42%] z-30 flex h-[52px] w-[36px] -translate-y-1/2 cursor-pointer items-center justify-center md:right-[max(0.75rem,calc(50%-min(600px,35vw)-3rem))] md:h-[62px] md:w-[34px]"
			data-tribes-next
			aria-label="Next tribe"
		>
			<span
				class="flex size-full items-center justify-center overflow-hidden [container-type:size]"
			>
				<span class="flex h-[100cqw] w-[100cqh] -rotate-90 items-center justify-center">
					<span class="relative block size-full overflow-hidden">
						<img
							src={assets.tribesChevron}
							alt=""
							class="pointer-events-none absolute left-0 top-[-41%] h-[182%] w-full max-w-none object-cover"
						/>
					</span>
				</span>
			</span>
		</button>

		<div
			class="flex justify-center gap-2 py-4"
			data-tribes-dots
			role="tablist"
			aria-label="Tribe slides"
			style="background: var(--color-snowbound-secondary);"
		>
			{
				tribeSlides.map((_, i) => (
					<button
						type="button"
						role="tab"
						aria-selected={i === 0 ? "true" : "false"}
						aria-label={`Show tribe ${i + 1}`}
						data-tribes-dot
						data-slide-index={i}
						class="tribes-dot size-2.5 rounded-full bg-white/90 shadow transition md:size-3"
					/>
				))
			}
		</div>
	</div>
</section>

<style>
	/* Stack all slides in the same grid cell */
	.tribes-slides-container {
		display: grid;
		grid-template-areas: "slide";
		isolation: isolate;
	}

	.tribes-slide {
		grid-area: slide;
		opacity: 0;
		pointer-events: none;
	}

	/*
	 * nav-next (siguiente): el actual sale hacia la izquierda; el nuevo entra desde la derecha.
	 * nav-prev (anterior): el actual sale hacia la derecha; el nuevo entra desde la izquierda.
	 * transform + animation-fill-mode: both para el frame inicial/final correcto.
	 */
	@keyframes tribes-in-from-right {
		from {
			transform: translate3d(100vw, 0, 0);
		}
		to {
			transform: translate3d(0, 0, 0);
		}
	}

	@keyframes tribes-in-from-left {
		from {
			transform: translate3d(-100vw, 0, 0);
		}
		to {
			transform: translate3d(0, 0, 0);
		}
	}

	@keyframes tribes-out-left {
		from {
			transform: translate3d(0, 0, 0);
		}
		to {
			transform: translate3d(-100vw, 0, 0);
		}
	}

	@keyframes tribes-out-right {
		from {
			transform: translate3d(0, 0, 0);
		}
		to {
			transform: translate3d(100vw, 0, 0);
		}
	}

	.tribes-slide.is-active {
		opacity: 1;
		pointer-events: auto;
		z-index: 2;
		transform: translate3d(0, 0, 0);
	}

	/* Entrante debajo del saliente */
	.tribes-slide.is-active.tribes-nav-next {
		z-index: 1;
		animation: tribes-in-from-right 0.5s ease both;
	}

	.tribes-slide.is-active.tribes-nav-prev {
		z-index: 1;
		animation: tribes-in-from-left 0.5s ease both;
	}

	.tribes-slide.is-leaving.tribes-nav-next {
		opacity: 1;
		pointer-events: none;
		z-index: 3;
		animation: tribes-out-left 0.5s ease both;
	}

	.tribes-slide.is-leaving.tribes-nav-prev {
		opacity: 1;
		pointer-events: none;
		z-index: 3;
		animation: tribes-out-right 0.5s ease both;
	}

	@media (prefers-reduced-motion: reduce) {
		.tribes-slide.is-active.tribes-nav-next,
		.tribes-slide.is-active.tribes-nav-prev,
		.tribes-slide.is-leaving.tribes-nav-next,
		.tribes-slide.is-leaving.tribes-nav-prev {
			animation: none;
		}
	}

	.tribes-dot[aria-selected="true"] {
		width: 0.875rem;
		height: 0.875rem;
		box-shadow:
			0 0 0 2px white,
			0 0 0 4px rgba(255, 255, 255, 0.35);
		transform: scale(1.15);
	}
	@media (min-width: 768px) {
		.tribes-dot[aria-selected="true"] {
			width: 1rem;
			height: 1rem;
		}
	}
</style>

<script>
	const root = document.querySelector("[data-tribes-root]");
	if (root) {
		const slidesContainer = root.querySelector("[data-tribes-slides]");
		const slides = root.querySelectorAll<HTMLElement>("[data-tribes-slide-index]");
		const prevBtn = root.querySelector<HTMLButtonElement>("[data-tribes-prev]");
		const nextBtn = root.querySelector<HTMLButtonElement>("[data-tribes-next]");
		const dots = root.querySelectorAll<HTMLButtonElement>("[data-tribes-dot]");

		const count = slides.length;
		const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

		let index = 0;
		let animating = false;

		function updateDots() {
			dots.forEach((dot, i) => {
				const on = i === index;
				dot.setAttribute("aria-selected", on ? "true" : "false");
				dot.tabIndex = on ? 0 : -1;
			});
		}

		/** Shortest path on the circle (for dot jumps). */
		function directionFromIndices(from: number, to: number): 1 | -1 {
			let d = to - from;
			if (d > count / 2) d -= count;
			if (d < -count / 2) d += count;
			if (d === 0) return 1;
			return d > 0 ? 1 : -1;
		}

		function goTo(newIndex: number, dir: 1 | -1) {
			const nextIndex = ((newIndex % count) + count) % count;
			if (nextIndex === index) return;
			if (animating) return;

			const oldSlide = slides[index];
			const newSlide = slides[nextIndex];

			if (reduceMotion) {
				oldSlide.classList.remove("is-active");
				oldSlide.setAttribute("aria-hidden", "true");
				newSlide.classList.add("is-active");
				newSlide.setAttribute("aria-hidden", "false");
				index = nextIndex;
				updateDots();
				return;
			}

			animating = true;
			/* 1 = siguiente (índice sube), -1 = anterior (índice baja) */
			const navNext = dir === 1;
			const navClass = navNext ? "tribes-nav-next" : "tribes-nav-prev";

			oldSlide.classList.remove("is-active");
			oldSlide.classList.add("is-leaving", navClass);
			oldSlide.setAttribute("aria-hidden", "true");

			newSlide.classList.add("is-active", navClass);
			newSlide.setAttribute("aria-hidden", "false");

			index = nextIndex;
			updateDots();

			let cleaned = false;
			const cleanup = () => {
				if (cleaned) return;
				cleaned = true;
				oldSlide.removeEventListener("animationend", onEnd);
				oldSlide.classList.remove("is-leaving", "tribes-nav-next", "tribes-nav-prev");
				newSlide.classList.remove("tribes-nav-next", "tribes-nav-prev");
				animating = false;
			};

			const onEnd = (e: AnimationEvent) => {
				if (e.target !== oldSlide) return;
				cleanup();
			};
			oldSlide.addEventListener("animationend", onEnd);
			window.setTimeout(cleanup, 520);
		}

		function go(delta: number) {
			goTo(index + delta, delta > 0 ? 1 : -1);
		}

		prevBtn?.addEventListener("click", () => go(-1));
		nextBtn?.addEventListener("click", () => go(1));

		dots.forEach((dot) => {
			dot.addEventListener("click", () => {
				const i = Number(dot.getAttribute("data-slide-index"));
				if (Number.isNaN(i)) return;
				goTo(i, directionFromIndices(index, i));
			});
		});

		slidesContainer?.addEventListener("keydown", (e) => {
			const key = (e as KeyboardEvent).key;
			if (key === "ArrowLeft") {
				e.preventDefault();
				go(-1);
			} else if (key === "ArrowRight") {
				e.preventDefault();
				go(1);
			}
		});

		// Touch on root. Use changedTouches + identifier: e.touches[0] is not always the finger that started on this surface.
		let touchStartX = 0;
		let touchStartY = 0;
		let touchActive = false;
		let touchId: number | null = null;

		function findTouch(list: TouchList, id: number): Touch | undefined {
			for (let i = 0; i < list.length; i++) {
				if (list[i].identifier === id) return list[i];
			}
			return undefined;
		}

		root.addEventListener(
			"touchstart",
			(e) => {
				if (touchActive) return;
				const t = e.changedTouches[0];
				if (!t) return;
				touchStartX = t.clientX;
				touchStartY = t.clientY;
				touchId = t.identifier;
				touchActive = true;
			},
			{ passive: true },
		);
		root.addEventListener(
			"touchend",
			(e) => {
				if (!touchActive || touchId === null) return;
				const t = findTouch(e.changedTouches, touchId);
				if (!t) return;
				touchActive = false;
				touchId = null;
				const dx = t.clientX - touchStartX;
				const dy = t.clientY - touchStartY;
				if (Math.abs(dx) < 48) return;
				if (Math.abs(dx) <= Math.abs(dy)) return;
				// Swipe left (dx < 0) → next; swipe right → previous
				go(dx < 0 ? 1 : -1);
			},
			{ passive: true },
		);
		root.addEventListener(
			"touchcancel",
			() => {
				touchActive = false;
				touchId = null;
			},
			{ passive: true },
		);

		updateDots();
	}
</script>

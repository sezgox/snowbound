---
import { assets } from "../data/figmaAssets";
import { tribeSlides, type TribeBackground } from "../data/tribes";

const n = tribeSlides.length;

function getBackgroundValue(background: TribeBackground) {
	return background.kind === "gradient" ? background.css : background.hex;
}

const initialBackground = getBackgroundValue(tribeSlides[0].background);
---

<section
	id="tribes"
	class="tribes-section relative w-full scroll-mt-24 overflow-hidden px-2 py-6 md:px-6 md:py-10"
	aria-labelledby="tribes-heading"
	data-tribes-root
	style={`--tribes-current-bg: ${initialBackground}; --tribes-next-bg: ${initialBackground};`}
>
	<div class="tribes-bg-overlay absolute inset-0 z-0" aria-hidden="true"></div>

	<h2
		id="tribes-heading"
		class="relative z-10 font-display text-center text-[clamp(2.8rem,7vw,4.75rem)] leading-none tracking-[0.04em] text-snowbound-secondary [text-shadow:0_3px_12px_rgba(255,255,255,0.2)]"
	>
		The Inuit Tribes
	</h2>

	<div
		class="tribes-carousel relative z-10 flex-1"
		data-tribes-slides
		role="region"
		aria-label="Tribe carousel"
		tabindex="0"
	>
		<button
			type="button"
			class="tribes-nav tribes-nav--prev"
			data-tribes-prev
			aria-label="Previous tribe"
		>
			<img
				src={assets.tribesChevron}
				alt=""
				class="pointer-events-none rotate-90"
			/>
		</button>

			{
				tribeSlides.map((slide, i) => {
					const slideId = `tribes-slide-${i}`;
					const backgroundValue = getBackgroundValue(slide.background);

					return (
						<article
							id={slideId}
							class={`tribes-slide${i === 0 ? " is-active" : ""}`}
							aria-roledescription="slide"
							aria-label={`Tribe ${i + 1} of ${n}`}
							aria-hidden={i === 0 ? "false" : "true"}
							data-tribes-slide-index={i}
							data-tribes-bg={backgroundValue}
						>
							<img
								src={slide.character}
								alt=""
								class="tribes-slide__character pointer-events-none"
							/>

							<div
								class="tribes-slide__panel"
								style={`background-image: url('${assets.tribesDescBgRotated}');`}
							>
								<h3 class="font-tillana text-[clamp(2rem,5vw,3.2rem)] font-medium leading-[0.95] tracking-[0.02em] text-black">
									{slide.name}
								</h3>

								<div class="font-nunito space-y-3 text-base leading-6 tracking-[0.01em] text-black md:text-lg md:leading-7">
									{
										slide.lines.map((line) => (
											<p class="mb-0">{line}</p>
										))
									}
								</div>
							</div>
						</article>
					);
				})
			}

		<button
			type="button"
			class="tribes-nav tribes-nav--next"
			data-tribes-next
			aria-label="Next tribe"
		>
			<img
				src={assets.tribesChevron}
				alt=""
				class="pointer-events-none -rotate-90"
			/>
		</button>
	</div>

	<div class="relative z-10 flex justify-center gap-2 pt-3 md:pt-4" role="tablist" aria-label="Tribe slides">
		{
			tribeSlides.map((_, i) => (
				<button
					type="button"
					role="tab"
					aria-controls={`tribes-slide-${i}`}
					aria-selected={i === 0 ? "true" : "false"}
					aria-label={`Show tribe ${i + 1}`}
					data-tribes-dot
					data-slide-index={i}
					class="tribes-dot"
				/>
			))
		}
	</div>
</section>

<style>
	.tribes-section {
		background: var(--tribes-current-bg);
		isolation: isolate;
	}

	.tribes-bg-overlay {
		background: var(--tribes-next-bg);
		opacity: 1;
		will-change: transform;
	}

	.tribes-section[data-tribes-bg-transition="on"] .tribes-bg-overlay {
		transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.tribes-section[data-tribes-bg-transition="off"] .tribes-bg-overlay {
		transition: none;
	}

	.tribes-section[data-tribes-bg-phase="idle-right"] .tribes-bg-overlay {
		transform: translate3d(100%, 0, 0);
	}

	.tribes-section[data-tribes-bg-phase="idle-left"] .tribes-bg-overlay {
		transform: translate3d(-100%, 0, 0);
	}

	.tribes-section[data-tribes-bg-phase="animating"] .tribes-bg-overlay {
		transform: translate3d(0, 0, 0);
	}

	.tribes-carousel {
		display: grid;
		grid-template-columns: 38px minmax(0, 1fr) 38px;
		align-items: center;
		min-height: 470px;
		touch-action: pan-y;
	}

	.tribes-carousel > .tribes-nav--prev {
		grid-column: 1;
		grid-row: 1;
	}

	.tribes-carousel > .tribes-nav--next {
		grid-column: 3;
		grid-row: 1;
	}

	.tribes-slide {
		grid-column: 2;
		grid-row: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		opacity: 0;
		pointer-events: none;
		touch-action: pan-y;
		padding: 1.5rem 3.5rem 0.75rem;
		transform: translate3d(0, 0, 0);
	}

	.tribes-slide.is-active {
		opacity: 1;
		pointer-events: auto;
		z-index: 2;
	}

	.tribes-slide.is-active.tribes-nav-next {
		z-index: 1;
		animation: tribes-in-from-right 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
	}

	.tribes-slide.is-active.tribes-nav-prev {
		z-index: 1;
		animation: tribes-in-from-left 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
	}

	.tribes-slide.is-leaving.tribes-nav-next {
		opacity: 1;
		pointer-events: none;
		z-index: 3;
		animation: tribes-out-left 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
	}

	.tribes-slide.is-leaving.tribes-nav-prev {
		opacity: 1;
		pointer-events: none;
		z-index: 3;
		animation: tribes-out-right 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
	}

	.tribes-slide__character {
		display: block;
		height: auto;
		width: 100%;
		max-width: 260px;
		object-fit: contain;
	}

	.tribes-slide__panel {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		min-height: 280px;
		width: min(100%, 460px);
		min-width: min(320px, 100%);
		padding: 2rem 2rem 2.25rem;
		background-position: center;
		background-repeat: no-repeat;
		background-size: 100% 100%;
		text-align: center;
	}

	.tribes-nav {
		display: flex;
		height: 54px;
		width: 38px;
		align-items: center;
		justify-content: center;
		border-radius: 9999px;
		background: rgba(255, 255, 255, 0.16);
		box-shadow:
			0 8px 24px rgba(17, 45, 87, 0.18),
			inset 0 0 0 1px rgba(255, 255, 255, 0.24);
		backdrop-filter: blur(6px);
		transition:
			transform 0.2s ease,
			background-color 0.2s ease;
	}

	@keyframes tribes-in-from-right {
		from {
			transform: translate3d(100%, 0, 0);
		}
		to {
			transform: translate3d(0, 0, 0);
		}
	}

	@keyframes tribes-in-from-left {
		from {
			transform: translate3d(-100%, 0, 0);
		}
		to {
			transform: translate3d(0, 0, 0);
		}
	}

	@keyframes tribes-out-left {
		from {
			transform: translate3d(0, 0, 0);
		}
		to {
			transform: translate3d(-100%, 0, 0);
		}
	}

	@keyframes tribes-out-right {
		from {
			transform: translate3d(0, 0, 0);
		}
		to {
			transform: translate3d(100%, 0, 0);
		}
	}

	.tribes-nav:hover {
		background: rgba(255, 255, 255, 0.24);
		transform: translateY(-2px);
	}

	.tribes-nav:focus-visible {
		outline: 2px solid white;
		outline-offset: 4px;
	}

	.tribes-dot {
		height: 0.7rem;
		width: 0.7rem;
		border-radius: 9999px;
		background: rgba(255, 255, 255, 0.88);
		box-shadow: 0 4px 10px rgba(17, 45, 87, 0.2);
		transition:
			transform 0.25s ease,
			box-shadow 0.25s ease,
			background-color 0.25s ease;
	}

	.tribes-dot:focus-visible {
		outline: 2px solid white;
		outline-offset: 3px;
	}

	.tribes-dot[aria-selected="true"] {
		transform: scale(1.18);
		box-shadow:
			0 0 0 2px white,
			0 0 0 5px rgba(255, 255, 255, 0.28);
	}

	@media (min-width: 768px) {
		.tribes-carousel {
			grid-template-columns: 42px minmax(0, 1fr) 42px;
			min-height: 500px;
		}

		.tribes-slide {
			min-height: 460px;
			flex-direction: row;
			gap: 0;
			padding: 1rem 4.5rem 1.25rem;
		}

		.tribes-slide__character {
			max-width: 360px;
			flex: 0 0 auto;
		}

		.tribes-slide__panel {
			flex: 0 1 auto;
			width: min(100%, 560px);
			min-height: 360px;
			min-width: 520px;
			padding: 2.4rem 3rem 2.6rem;
		}

		.tribes-nav {
			height: 62px;
			width: 42px;
		}

		.tribes-dot {
			height: 0.8rem;
			width: 0.8rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.tribes-bg-overlay,
		.tribes-nav,
		.tribes-dot,
		.tribes-slide.is-active.tribes-nav-next,
		.tribes-slide.is-active.tribes-nav-prev,
		.tribes-slide.is-leaving.tribes-nav-next,
		.tribes-slide.is-leaving.tribes-nav-prev {
			transition: none !important;
			animation: none !important;
		}
	}
</style>

<script>
	const TRIBES_TRANSITION_MS = 550;
	type TribesBgPhase = "idle-right" | "idle-left" | "animating";

	function initTribesSection() {
		document.querySelectorAll<HTMLElement>("[data-tribes-root]").forEach((root) => {
			if (root.dataset.tribesBound === "true") return;
			root.dataset.tribesBound = "true";

			const bgOverlay = root.querySelector<HTMLElement>(".tribes-bg-overlay");
			const slidesRegion = root.querySelector<HTMLElement>("[data-tribes-slides]");
			const slides = Array.from(
				root.querySelectorAll<HTMLElement>("[data-tribes-slide-index]"),
			);
			const prevBtn = root.querySelector<HTMLButtonElement>("[data-tribes-prev]");
			const nextBtn = root.querySelector<HTMLButtonElement>("[data-tribes-next]");
			const dots = Array.from(
				root.querySelectorAll<HTMLButtonElement>("[data-tribes-dot]"),
			);
			const motionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");

			if (!bgOverlay || !slidesRegion || slides.length === 0) return;

			const count = slides.length;
			let index = 0;
			let animating = false;
			let cleanupTimeout = 0;

			function prefersReducedMotion() {
				return motionQuery.matches;
			}

			function updateDots() {
				dots.forEach((dot, i) => {
					const active = i === index;
					dot.setAttribute("aria-selected", active ? "true" : "false");
					dot.tabIndex = active ? 0 : -1;
				});
			}

			function setCurrentBackground(value: string) {
				root.style.setProperty("--tribes-current-bg", value);
				root.style.setProperty("--tribes-next-bg", value);
			}

			function setOverlayTransition(enabled: boolean) {
				root.dataset.tribesBgTransition = enabled ? "on" : "off";
			}

			function setOverlayPhase(phase: TribesBgPhase) {
				root.dataset.tribesBgPhase = phase;
			}

			function prepareOverlay(nextBackground: string, phase: TribesBgPhase) {
				root.style.setProperty("--tribes-next-bg", nextBackground);
				setOverlayTransition(false);
				setOverlayPhase(phase);
				void bgOverlay.offsetWidth;
			}

			function animateOverlayIn(phase: TribesBgPhase) {
				window.requestAnimationFrame(() => {
					setOverlayTransition(true);

					window.requestAnimationFrame(() => {
						if (!animating) return;
						if (root.dataset.tribesBgPhase !== phase) return;
						setOverlayPhase("animating");
					});
				});
			}

			function directionFromIndices(from: number, to: number): 1 | -1 {
				let distance = to - from;

				if (distance > count / 2) distance -= count;
				if (distance < -count / 2) distance += count;
				if (distance === 0) return 1;

				return distance > 0 ? 1 : -1;
			}

			function cleanupTransition(nextBackground: string, phase: TribesBgPhase) {
				window.clearTimeout(cleanupTimeout);
				setCurrentBackground(nextBackground);
				setOverlayTransition(false);
				setOverlayPhase(phase);
				animating = false;
			}

			function goTo(newIndex: number, dir: 1 | -1) {
				const nextIndex = ((newIndex % count) + count) % count;
				if (nextIndex === index || animating) return;

				const currentSlide = slides[index];
				const nextSlide = slides[nextIndex];
				const nextBackground = nextSlide.dataset.tribesBg ?? "";

				if (prefersReducedMotion()) {
					currentSlide.classList.remove("is-active");
					currentSlide.setAttribute("aria-hidden", "true");
					nextSlide.classList.add("is-active");
					nextSlide.setAttribute("aria-hidden", "false");
					index = nextIndex;
					updateDots();
					setCurrentBackground(nextBackground);
					return;
				}

				animating = true;
				const navClass = dir === 1 ? "tribes-nav-next" : "tribes-nav-prev";
				const overlayStartPhase: TribesBgPhase =
					dir === 1 ? "idle-right" : "idle-left";
				prepareOverlay(nextBackground, overlayStartPhase);
				currentSlide.classList.remove("is-active");
				currentSlide.classList.add("is-leaving", navClass);
				currentSlide.setAttribute("aria-hidden", "true");
				nextSlide.classList.add("is-active", navClass);
				nextSlide.setAttribute("aria-hidden", "false");
				index = nextIndex;
				updateDots();
				animateOverlayIn(overlayStartPhase);

				let cleaned = false;
				const cleanup = () => {
					if (cleaned) return;
					cleaned = true;
					currentSlide.removeEventListener("animationend", onEnd);
					currentSlide.classList.remove("is-leaving", "tribes-nav-next", "tribes-nav-prev");
					nextSlide.classList.remove("tribes-nav-next", "tribes-nav-prev");
					cleanupTransition(nextBackground, overlayStartPhase);
				};

				const onEnd = (event: AnimationEvent) => {
					if (event.target !== currentSlide) return;
					cleanup();
				};

				currentSlide.addEventListener("animationend", onEnd);
				cleanupTimeout = window.setTimeout(() => {
					cleanup();
				}, TRIBES_TRANSITION_MS + 40);
			}

			function go(delta: number) {
				goTo(index + delta, delta > 0 ? 1 : -1);
			}

			prevBtn?.addEventListener("click", () => go(-1));
			nextBtn?.addEventListener("click", () => go(1));

			dots.forEach((dot) => {
				dot.addEventListener("click", () => {
					const dotIndex = Number(dot.dataset.slideIndex);
					if (Number.isNaN(dotIndex)) return;
					goTo(dotIndex, directionFromIndices(index, dotIndex));
				});
			});

			slidesRegion.addEventListener("keydown", (event) => {
				const key = (event as KeyboardEvent).key;
				if (key === "ArrowLeft") {
					event.preventDefault();
					go(-1);
				}

				if (key === "ArrowRight") {
					event.preventDefault();
					go(1);
				}
			});

			let touchStartX = 0;
			let touchStartY = 0;
			let touchId: number | null = null;

			function findTouch(list: TouchList, targetId: number) {
				for (let touchIndex = 0; touchIndex < list.length; touchIndex += 1) {
					if (list[touchIndex].identifier === targetId) {
						return list[touchIndex];
					}
				}

				return undefined;
			}

			root.addEventListener(
				"touchstart",
				(event) => {
					const touch = event.changedTouches[0];
					if (!touch) return;

					touchStartX = touch.clientX;
					touchStartY = touch.clientY;
					touchId = touch.identifier;
				},
				{ passive: true },
			);

			root.addEventListener(
				"touchend",
				(event) => {
					if (touchId === null) return;

					const touch = findTouch(event.changedTouches, touchId);
					touchId = null;
					if (!touch) return;

					const dx = touch.clientX - touchStartX;
					const dy = touch.clientY - touchStartY;
					if (Math.abs(dx) < 48 || Math.abs(dx) <= Math.abs(dy)) return;

					go(dx < 0 ? 1 : -1);
				},
				{ passive: true },
			);

			root.addEventListener(
				"touchcancel",
				() => {
					touchId = null;
				},
				{ passive: true },
			);

			setOverlayTransition(false);
			setOverlayPhase("idle-right");
			updateDots();
			slides.forEach((slide, slideIndex) => {
				slide.setAttribute("aria-hidden", slideIndex === 0 ? "false" : "true");
				slide.classList.toggle("is-active", slideIndex === 0);
			});
			setCurrentBackground(slides[0].dataset.tribesBg ?? "");
		});
	}

	initTribesSection();
	document.addEventListener("astro:page-load", initTribesSection);
</script>

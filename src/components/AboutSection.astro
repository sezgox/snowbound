---
import { assets } from "../data/figmaAssets";
import type { Messages } from "../i18n";

interface Props {
	messages: Messages["about"];
}

const { messages } = Astro.props;
---

<section
	id="about"
	class="flex w-full flex-col items-center gap-2.5 bg-gradient-to-b from-[#2395e7] to-white py-10 scroll-mt-24"
	aria-labelledby="about-heading"
	data-about-reveal
>
	<div
		class="section-inner flex w-full flex-col gap-6 rounded-2xl px-4 pb-8 pt-12 sm:px-8 md:px-12"
	>
		<h2
			id="about-heading"
			class="about-impact about-impact--title font-display w-full text-center text-4xl leading-tight tracking-wide text-white md:text-[64px] md:leading-[64px]"
			style="--about-impact-delay: 0.05s;"
		>
			{messages.heading}
		</h2>

		<div class="relative grid w-full gap-10 md:grid-cols-2 md:gap-8">
			<div class="flex flex-col items-center gap-4">
				<div
					class="about-impact relative h-[226px] w-full overflow-hidden rounded-[10px] border-2 border-[#99a1af]"
					style="--about-impact-delay: 0.18s;"
				>
					<img
						src={assets.aboutTeam}
						alt={messages.teamAlt}
						class="absolute left-0 w-full max-w-none object-cover"
						style="height: 302.06%; top: -85.16%;"
					/>
				</div>
				<p
					class="about-impact font-inter text-center text-base leading-6 tracking-tight text-[#1d293d]"
					style="--about-impact-delay: 0.31s;"
				>
					{messages.teamNames}
				</p>
			</div>

			<div class="flex flex-col gap-4 pt-2 text-white md:pt-2.5">
				<p
					class="about-impact font-inter text-base leading-6 tracking-tight text-white md:max-w-[492px]"
					style="--about-impact-delay: 0.44s;"
				>
					{messages.paragraphs[0]}
				</p>
				<p
					class="about-impact font-inter text-base leading-6 tracking-tight text-[#1d293d] md:max-w-full"
					style="--about-impact-delay: 0.57s;"
				>
					{messages.paragraphs[1]}
				</p>
			</div>
		</div>
	</div>

	<div class="flex w-full flex-col items-center gap-4 px-3 py-5 sm:px-4">
		<div
			class="about-impact about-impact--heavy flex w-full flex-col items-center gap-4"
			style="--about-impact-delay: 0.74s;"
		>
			<button
				type="button"
				data-open-waitlist
				class="font-tillana flex w-full items-center justify-center rounded-[50px] bg-[#0285e4] px-4 py-2.5 text-lg leading-none tracking-tight text-white shadow-[0_4px_31px_rgba(0,0,0,0.15)] transition hover:bg-[#0270c2] max-md:min-h-[56px] max-md:whitespace-nowrap md:h-[78px]  md:text-[48px] md:leading-8 md:tracking-[0.1px]"
			>
				{messages.cta}
			</button>
			<p
				class="font-roboto max-w-[557px] px-2.5 text-center text-xl leading-7 tracking-[0.2px] text-[#112d57]"
			>
				{messages.tagline}
			</p>
		</div>
	</div>
</section>

<noscript>
	<style>
		[data-about-reveal] .about-impact {
			opacity: 1 !important;
			transform: none !important;
			animation: none !important;
		}
	</style>
</noscript>

<style>
	#about {
		overflow-x: clip;
	}

	#about .about-impact {
		--about-impact-start-scale: 2.6;
		opacity: 0;
		position: relative;
		transform-origin: center top;
		transform: translate3d(0, -7rem, 0) scale(var(--about-impact-start-scale));
		will-change: transform, opacity;
		backface-visibility: hidden;
	}

	#about .about-impact--title {
		--about-impact-start-scale: 2.9;
	}

	#about .about-impact--heavy {
		--about-impact-start-scale: 3.1;
	}

	#about.is-in-view .about-impact {
		animation: about-impact-drop 0.84s cubic-bezier(0.18, 0.88, 0.24, 1) both;
		animation-delay: var(--about-impact-delay, 0s);
	}

	@keyframes about-impact-drop {
		0% {
			opacity: 0;
			transform: translate3d(0, -7rem, 0) scale(var(--about-impact-start-scale));
		}
		100% {
			opacity: 1;
			transform: translate3d(0, 0, 0) scale(1);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		#about .about-impact {
			opacity: 1;
			transform: none;
			animation: none !important;
			will-change: auto;
		}
	}
</style>

<script is:inline>
	function aboutHeightVisibleRatio(el, marginBottomRatio) {
		const rect = el.getBoundingClientRect();
		const vh = window.innerHeight;
		const m = marginBottomRatio ?? 0;
		const viewportBottom = vh * (1 - m);
		const visibleTop = Math.max(0, rect.top);
		const visibleBottom = Math.min(viewportBottom, rect.bottom);
		const visibleHeight = Math.max(0, visibleBottom - visibleTop);
		if (rect.height <= 0) return 0;
		return visibleHeight / rect.height;
	}

	function initAboutReveal() {
		document.querySelectorAll("[data-about-reveal]").forEach((root) => {
			if (!(root instanceof HTMLElement)) return;
			if (root.dataset.aboutBound === "true") return;
			root.dataset.aboutBound = "true";

			const motionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
			const minRatio = 0.3;
			const rootMarginBottomPct = 10;

			const markInView = () => {
				root.classList.add("is-in-view");
			};

			if (motionQuery.matches) {
				markInView();
				return;
			}

			if (
				aboutHeightVisibleRatio(root, rootMarginBottomPct / 100) >=
				minRatio - 0.02
			) {
				markInView();
				return;
			}

			if (!("IntersectionObserver" in window)) {
				markInView();
				return;
			}

			const io = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						if (entry.intersectionRatio >= minRatio) {
							markInView();
							io.unobserve(entry.target);
							break;
						}
					}
				},
				{
					threshold: [0, 0.15, 0.3, 0.45],
					rootMargin: `0px 0px -${rootMarginBottomPct}% 0px`,
				},
			);

			io.observe(root);
		});
	}

	initAboutReveal();
	document.addEventListener("astro:page-load", initAboutReveal);
</script>

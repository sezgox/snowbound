---
import { defaultLocale, getMessages, type Locale, type Messages } from "../i18n";

interface Props {
	variant?: "hero" | "inline";
	id?: string;
	locale?: Locale;
	messages?: Messages["waitlist"];
}

const {
	variant = "hero",
	id = "waitlist-form",
	locale = defaultLocale,
	messages = getMessages(locale).waitlist,
} = Astro.props;
const isHero = variant === "hero";
---

<form
	id={id}
	class:list={[
		"flex flex-col gap-3",
		isHero ? "items-center" : "w-full max-w-md",
	]}
	data-waitlist-form
	data-locale={locale}
	data-newsletter-label={messages.newsletterLabel}
	data-empty-message={messages.status.empty}
	data-pending-message={messages.status.pending}
	data-success-message={messages.status.success}
	data-not-configured-message={messages.status.notConfigured}
	data-generic-error-message={messages.status.genericError}
>
	<div
		class:list={[
			"flex w-full flex-col gap-2 sm:flex-row sm:items-stretch",
			isHero ? "max-w-xl justify-center px-4" : "",
		]}
	>
		<label class="sr-only" for={`${id}-email`}>{messages.emailLabel}</label>
		<input
			id={`${id}-email`}
			name="user_email"
			type="email"
			required
			placeholder={messages.emailPlaceholder}
			autocomplete="email"
			class="font-nunito min-h-[48px] flex-1 rounded-full border border-[#77abbd] bg-white px-5 text-base text-[#112d57] placeholder:text-[#5c5c5c]/70"
		/>
	</div>
	<button
		type="submit"
		data-waitlist-submit
		class:list={[
			"font-tillana inline-flex items-center justify-center rounded-[50px] bg-[#0285e4] px-10 py-4 text-2xl leading-8 tracking-wide text-white shadow-[0_4px_31px_rgba(0,0,0,0.15)] transition enabled:hover:bg-[#0270c2] disabled:cursor-not-allowed disabled:opacity-60 md:px-[70px] md:py-5 md:text-5xl md:leading-8",
		]}
	>
		{messages.submit}
	</button>
	<p
		class="font-nunito hidden max-w-xl px-2 text-center text-sm text-[#5c5c5c]"
		data-waitlist-status
		aria-live="polite"
	>
	</p>
</form>

<script>
	import { submitWaitlist } from "../scripts/waitlist-submit";

	function showStatus(
		el: HTMLElement | null,
		text: string,
		isError: boolean,
	) {
		if (!el) return;
		el.classList.remove("hidden", "text-red-600", "text-[#5c5c5c]");
		el.classList.add(isError ? "text-red-600" : "text-[#5c5c5c]");
		el.textContent = text;
	}

	const forms = document.querySelectorAll<HTMLFormElement>("[data-waitlist-form]");

	forms.forEach((form) => {
		form.addEventListener("submit", async (e) => {
			e.preventDefault();
			const status = form.querySelector<HTMLElement>("[data-waitlist-status]");
			const submitBtn = form.querySelector<HTMLButtonElement>("[data-waitlist-submit]");
			const emailInput = form.querySelector<HTMLInputElement>('[name="user_email"]');
			const email = emailInput?.value.trim() ?? "";
			const locale = form.dataset.locale === "es" ? "es" : "en";
			const newsletterLabel = form.dataset.newsletterLabel ?? "Snowbound newsletter";
			const emptyMessage = form.dataset.emptyMessage ?? "Please enter your email.";
			const pendingMessage = form.dataset.pendingMessage ?? "Subscribing…";
			const successMessage =
				form.dataset.successMessage ??
				"Thanks! You are on the list — we will be in touch.";
			const notConfiguredMessage =
				form.dataset.notConfiguredMessage ??
				"Email not configured yet — we still noted your interest!";
			const genericErrorMessage =
				form.dataset.genericErrorMessage ??
				"Something went wrong. Please try again.";

			if (!email) {
				showStatus(status, emptyMessage, true);
				return;
			}

			if (submitBtn) submitBtn.disabled = true;
			showStatus(status, pendingMessage, false);

			try {
				await submitWaitlist(email, locale, newsletterLabel);
				showStatus(status, successMessage, false);
				form.reset();
			} catch (err) {
				const msg =
					err instanceof Error && err.message === "not_configured"
						? notConfiguredMessage
						: err instanceof Error && err.message !== "request_failed"
							? err.message
							: genericErrorMessage;
				showStatus(status, msg, true);
			}

			if (submitBtn) submitBtn.disabled = false;
		});
	});
</script>

---
import flake0 from "../assets/snowflakes/snowflake-0.svg?raw";
import flake1 from "../assets/snowflakes/snowflake-1.svg?raw";
import flake2 from "../assets/snowflakes/snowflake-2.svg?raw";
import flake3 from "../assets/snowflakes/snowflake-3.svg?raw";
import flake4 from "../assets/snowflakes/snowflake-4.svg?raw";
import flake5 from "../assets/snowflakes/snowflake-5.svg?raw";
import flake6 from "../assets/snowflakes/snowflake-6.svg?raw";
import flake7 from "../assets/snowflakes/snowflake-7.svg?raw";
import flake8 from "../assets/snowflakes/snowflake-8.svg?raw";
import flake9 from "../assets/snowflakes/snowflake-9.svg?raw";

const flakes = [flake0, flake1, flake2, flake3, flake4, flake5, flake6, flake7, flake8, flake9];

interface Props {
	variant: number;
}
const { variant } = Astro.props;
const html = flakes[((variant % flakes.length) + flakes.length) % flakes.length];
---

<span class="hero-snowflake-embed" set:html={html} />

<style>
	.hero-snowflake-embed {
		display: flex;
		width: 100%;
		height: 100%;
		align-items: center;
		justify-content: center;
		line-height: 0;
	}
	.hero-snowflake-embed :global(.hero-snowfield-flake) {
		display: block;
		width: 100%;
		height: 100%;
	}
</style>

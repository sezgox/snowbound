---
import { assets } from "../data/figmaAssets";

const footerTagline = "Get Snowbound!";
const footerTaglineChars = Array.from(footerTagline);
---

<footer
	class="relative flex w-full shrink-0 flex-col items-center justify-center overflow-hidden bg-[#112d57] py-8"
	data-footer-glow
>
	<div
		class="section-inner flex flex-col items-center gap-6 px-4 md:h-[133px] md:flex-row md:justify-between md:gap-4"
	>
		<div class="flex flex-col items-center md:items-start">
			<div class="flex w-[196px] items-start overflow-hidden px-2.5">
				<div class="relative h-[58px] w-[186px] shrink-0">
					<img
						src={assets.footerLogo}
						alt="Snowbound"
						class="pointer-events-none absolute inset-0 size-full max-w-none object-contain"
					/>
				</div>
			</div>
		</div>

		<div class="flex items-center gap-7">
			<a
				href="mailto:support@snowboundbg.com"
				class="footer-social-link relative block size-[50px] overflow-hidden rounded-full hover:opacity-90"
				aria-label="Email"
				title="support@snowboundbg.com"
				data-tooltip="support@snowboundbg.com"
			>
				<span class="absolute inset-[16.67%_8.33%]">
					<img src={assets.iconMail} alt="" class="block size-full max-w-none" />
				</span>
			</a>
			<a
				href="#"
				class="footer-social-link relative block size-[50px] hover:opacity-90"
				aria-label="Facebook"
				title="Facebook: nombre_facebook"
				data-tooltip="Facebook: nombre_facebook"
			>
				<img
					src={assets.iconFacebook}
					alt=""
					class="absolute block size-full max-w-none"
				/>
			</a>
			<a
				href="https://www.instagram.com/bigc.ountrygames/"
				class="footer-social-link relative block size-12 overflow-hidden hover:opacity-90"
				aria-label="Instagram"
				title="Instagram: @bigc.ountrygames"
				data-tooltip="Instagram: @bigc.ountrygames"
			>
				<span class="absolute inset-[8.33%]">
					<img src={assets.iconInstagram} alt="" class="block size-full max-w-none" />
				</span>
			</a>
		</div>

		<p
			class="footer-glow-text font-roboto text-center text-[13px] leading-[23px] tracking-wide text-white md:text-right"
			aria-label={footerTagline}
			style={`--footer-glow-count: ${footerTaglineChars.length};`}
		>
			{
				footerTaglineChars.map((char, i) => (
					<span
						class="footer-glow-letter"
						aria-hidden="true"
					>
						{char === " " ? "\u00A0" : char}
					</span>
				))
			}
		</p>
	</div>
</footer>

<style>
	.footer-glow-text {
		display: inline-flex;
		flex-wrap: wrap;
		justify-content: center;
	}

	.footer-social-link::after {
		content: attr(data-tooltip);
		position: absolute;
		left: 50%;
		bottom: calc(100% + 0.6rem);
		z-index: 20;
		min-width: max-content;
		max-width: min(80vw, 18rem);
		padding: 0.35rem 0.55rem;
		border-radius: 0.5rem;
		background: rgba(255, 255, 255, 0.96);
		color: #112d57;
		font-family: var(--font-roboto);
		font-size: 0.75rem;
		line-height: 1.2;
		text-align: center;
		box-shadow: 0 10px 22px rgba(0, 0, 0, 0.2);
		opacity: 0;
		transform: translate3d(-50%, 0.25rem, 0);
		pointer-events: none;
		transition:
			opacity 0.18s ease,
			transform 0.18s ease;
		white-space: nowrap;
	}

	.footer-social-link:hover::after,
	.footer-social-link:focus-visible::after {
		opacity: 1;
		transform: translate3d(-50%, 0, 0);
	}

	.footer-glow-letter {
		display: inline-block;
		color: rgba(255, 255, 255, 0.7);
		text-shadow: 0 0 0 rgba(255, 255, 255, 0);
		transition:
			color 0.18s ease,
			text-shadow 0.18s ease;
	}

	.footer-glow-letter.is-lit {
		color: rgba(255, 255, 255, 1);
		text-shadow:
			0 0 8px rgba(255, 255, 255, 0.85),
			0 0 16px rgba(111, 196, 255, 0.8),
			0 0 28px rgba(2, 133, 228, 0.65);
	}

	.footer-glow-letter.is-lit-near {
		color: rgba(255, 255, 255, 0.88);
		text-shadow:
			0 0 5px rgba(255, 255, 255, 0.65),
			0 0 10px rgba(111, 196, 255, 0.45),
			0 0 18px rgba(2, 133, 228, 0.3);
	}

	@media (prefers-reduced-motion: reduce) {
		.footer-social-link::after {
			transition: none;
		}

		.footer-glow-letter {
			color: rgba(255, 255, 255, 1);
			text-shadow: none;
			transition: none;
		}
	}
</style>

<script is:inline>
	function initFooterGlow() {
		document.querySelectorAll("[data-footer-glow]").forEach((root) => {
			if (!(root instanceof HTMLElement)) return;
			if (root.dataset.footerGlowBound === "true") return;
			root.dataset.footerGlowBound = "true";

			const motionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
			const letters = Array.from(
				root.querySelectorAll(".footer-glow-letter"),
			).filter((letter) => letter instanceof HTMLElement);

			if (letters.length === 0 || motionQuery.matches) return;

			let index = 0;
			let direction = 1;

			const paint = () => {
				letters.forEach((letter, letterIndex) => {
					const distance = Math.abs(letterIndex - index);
					letter.classList.toggle("is-lit", distance === 0);
					letter.classList.toggle("is-lit-near", distance === 1);
				});
			};

			paint();

			window.setInterval(() => {
				if (index === letters.length - 1) direction = -1;
				else if (index === 0) direction = 1;

				index += direction;
				paint();
			}, 110);
		});
	}

	initFooterGlow();
	document.addEventListener("astro:page-load", initFooterGlow);
</script>

<noscript>
	<style>
		[data-game-stats] .game-stats-inner,
		[data-game-stats] .game-stats-svg {
			opacity: 1 !important;
			transform: none !important;
			animation: none !important;
		}
	</style>
</noscript>

<style>
	.game-stats-inner {
		opacity: 0;
		transform: translate3d(-2.5rem, 0, 0);
		transition:
			opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1),
			transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
		will-change: opacity, transform;
	}

	.game-stats.is-in-view .game-stats-inner {
		opacity: 1;
		transform: translate3d(0, 0, 0);
	}

	.game-stats-svg {
		opacity: 0;
		transform: rotate(-540deg) scale(0.92);
		transform-origin: center center;
	}

	.game-stats.is-in-view .game-stats-svg {
		animation: game-stats-svg-spin-in 0.95s cubic-bezier(0.34, 1.2, 0.64, 1) forwards;
	}

	.game-stats.is-in-view .game-stats-column:nth-child(1) .game-stats-svg {
		animation-delay: 0.08s;
	}

	.game-stats.is-in-view .game-stats-column:nth-child(2) .game-stats-svg {
		animation-delay: 0.22s;
	}

	.game-stats.is-in-view .game-stats-column:nth-child(3) .game-stats-svg {
		animation-delay: 0.36s;
	}

	@keyframes game-stats-svg-spin-in {
		from {
			opacity: 0;
			transform: rotate(-540deg) scale(0.92);
		}
		to {
			opacity: 1;
			transform: rotate(0deg) scale(1);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.game-stats-inner {
			opacity: 1;
			transform: none;
			transition: none;
			will-change: auto;
		}

		.game-stats-svg {
			opacity: 1;
			transform: none;
			animation: none !important;
		}
	}
</style>

<script>
	/** Alineado con Lore: ratio visible / alto; `marginBottomRatio` = rootMargin inferior (p. ej. 0.15). */
	function gameStatsHeightVisibleRatio(el, marginBottomRatio) {
		const rect = el.getBoundingClientRect();
		const vh = window.innerHeight;
		const m = marginBottomRatio ?? 0;
		const viewportBottom = vh * (1 - m);
		const visibleTop = Math.max(0, rect.top);
		const visibleBottom = Math.min(viewportBottom, rect.bottom);
		const visibleHeight = Math.max(0, visibleBottom - visibleTop);
		if (rect.height <= 0) return 0;
		return visibleHeight / rect.height;
	}

	function initGameStatsReveal() {
		const root = document.querySelector("[data-game-stats]");
		if (!root) return;

		const minRatio = 0.3;
		const rootMarginBottomPct = 15;

		const markInView = () => {
			root.classList.add("is-in-view");
		};

		if (
			gameStatsHeightVisibleRatio(root, rootMarginBottomPct / 100) >=
			minRatio - 0.02
		) {
			markInView();
			return;
		}

		if (!("IntersectionObserver" in window)) {
			markInView();
			return;
		}

		const io = new IntersectionObserver(
			(entries) => {
				for (const e of entries) {
					if (e.intersectionRatio >= minRatio) {
						markInView();
						io.unobserve(e.target);
						break;
					}
				}
			},
			{
				threshold: minRatio,
				rootMargin: `0px 0px -${rootMarginBottomPct}% 0px`,
			},
		);
		io.observe(root);
	}

	initGameStatsReveal();
	document.addEventListener("astro:page-load", initGameStatsReveal);
</script>

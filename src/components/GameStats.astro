---
import { assets } from "../data/figmaAssets";
---

<section class="w-full bg-[#faf9f2] py-10 flex sm:flex-col md:flex-row justify-between" aria-label="Game facts">
	<div
		class="section-inner flex flex-wrap items-center justify-center gap-12 px-4 md:justify-between md:gap-8"
	>
	<div class="relative flex flex-col items-start gap-0.5">
		<div class="relative h-[118px] w-[88px] shrink-0 overflow-hidden rounded-t-sm">
			<img
				src={assets.pjSil}
				alt=""
				class="pointer-events-none absolute inset-0 size-full max-w-none rounded-t-sm object-cover"
			/>
		</div>
		<div
			class="flex h-11 w-full flex-col items-center justify-center rounded-b-sm bg-[#faf9f2] px-4"
		>
			<p
				class="font-display text-center text-2xl text-black uppercase"
			>
				2 - 6
			</p>
		</div>
		<div
			class="pointer-events-none absolute -left-1 top-7 flex h-[71px] w-[102px] items-center justify-center gap-1 opacity-30"
			aria-hidden="true"
		>
			<div class="relative h-[101px] w-[72px] overflow-hidden rounded-t-sm">
				<img
					src={assets.pjSil}
					alt=""
					class="absolute inset-0 size-full object-cover opacity-60"
				/>
			</div>
			<div class="relative h-[101px] w-[72px] overflow-hidden rounded-t-sm">
				<img
					src={assets.pjSil}
					alt=""
					class="absolute inset-0 size-full object-cover"
				/>
			</div>
		</div>
	</div>

	<div class="flex flex-col items-start gap-0.5">
		<div
			class="flex h-[71px] w-full flex-col items-center justify-center overflow-hidden rounded-t-sm"
		>
			<div class="relative h-[86px] w-[53px] shrink-0">
				<img
					src={assets.hourglass}
					alt=""
					class="absolute block size-full max-w-none"
				/>
			</div>
		</div>
		<div
			class="flex h-11 w-full flex-col items-center justify-center rounded-b-sm bg-[#faf9f2] px-4"
		>
			<p class="font-display text-center text-2xl text-black uppercase">
				30 - 45
			</p>
		</div>
	</div>

	<div class="flex flex-col items-start gap-0.5">
		<div
			class="flex h-[71px] w-full flex-col items-center justify-center overflow-hidden rounded-t-sm"
		>
			<div class="relative inline-grid shrink-0 place-items-start">
				<div class="relative col-start-1 row-start-1 ml-0 mt-7 h-[68px] w-12">
					<img
						src={assets.pjSil2}
						alt=""
						class="pointer-events-none absolute inset-0 size-full object-cover"
					/>
				</div>
				<div class="relative col-start-1 row-start-1 ml-5 mt-0 h-[105px] w-20">
					<img
						src={assets.pjSil}
						alt=""
						class="pointer-events-none absolute inset-0 size-full object-cover"
					/>
				</div>
			</div>
		</div>
		<div
			class="flex h-11 w-full flex-col items-center justify-center rounded-b-sm bg-[#faf9f2] px-4"
		>
			<p class="font-display text-center text-[28px] text-black uppercase">9+</p>
		</div>
	</div>
	</div>
</section>

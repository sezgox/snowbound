---
import { assets } from "../data/figmaAssets";
import { localePath, type Locale, type Messages } from "../i18n";
import HeroSnowflakeInner from "./HeroSnowflakeInner.astro";

interface Props {
	locale: Locale;
	messages: Messages["hero"];
}

const { locale, messages } = Astro.props;

/** 36 posiciones base; se duplican en 2 capas (72 copos). 10 diseños SVG en ciclo (`i % 10`). */
const snowParticleBase = [
	{ left: 6, w: 5, h: 5, drift: 11, delay: -3.5, dur: 28 },
	{ left: 14, w: 8, h: 8, drift: -9, delay: -12, dur: 19 },
	{ left: 23, w: 6, h: 6, drift: 14, delay: -7, dur: 39 },
	{ left: 31, w: 9, h: 9, drift: -16, delay: -18, dur: 25 },
	{ left: 40, w: 7, h: 7, drift: 7, delay: -2, dur: 17 },
	{ left: 49, w: 5, h: 5, drift: -5, delay: -14, dur: 35 },
	{ left: 58, w: 9, h: 9, drift: 18, delay: -9, dur: 31 },
	{ left: 66, w: 6, h: 6, drift: -12, delay: -20, dur: 18 },
	{ left: 74, w: 8, h: 8, drift: 6, delay: -5, dur: 37 },
	{ left: 82, w: 5, h: 5, drift: -14, delay: -16, dur: 23 },
	{ left: 90, w: 9, h: 9, drift: 10, delay: -11, dur: 33 },
	{ left: 96, w: 6, h: 6, drift: -7, delay: -22, dur: 16 },
	{ left: 10, w: 7, h: 7, drift: 15, delay: -24, dur: 29 },
	{ left: 27, w: 5, h: 5, drift: -11, delay: -8, dur: 18 },
	{ left: 44, w: 9, h: 9, drift: 8, delay: -17, dur: 39 },
	{ left: 62, w: 6, h: 6, drift: -17, delay: -4.5, dur: 25 },
	{ left: 79, w: 7, h: 7, drift: 5, delay: -12, dur: 34 },
	{ left: 88, w: 5, h: 5, drift: -13, delay: -25, dur: 20 },
	{ left: 3, w: 6, h: 6, drift: 9, delay: -27, dur: 32 },
	{ left: 18, w: 7, h: 7, drift: -8, delay: -10, dur: 21 },
	{ left: 35, w: 5, h: 5, drift: 16, delay: -21, dur: 38 },
	{ left: 52, w: 8, h: 8, drift: -6, delay: -3, dur: 24 },
	{ left: 68, w: 6, h: 6, drift: 12, delay: -15, dur: 27 },
	{ left: 85, w: 9, h: 9, drift: -15, delay: -6, dur: 40 },
	{ left: 1, w: 5, h: 5, drift: 4, delay: -29, dur: 26 },
	{ left: 12, w: 6, h: 6, drift: -10, delay: -12, dur: 30 },
	{ left: 29, w: 8, h: 8, drift: 13, delay: -23, dur: 18 },
	{ left: 46, w: 5, h: 5, drift: -4, delay: -4, dur: 36 },
	{ left: 63, w: 7, h: 7, drift: 17, delay: -18, dur: 22 },
	{ left: 77, w: 6, h: 6, drift: -18, delay: -9, dur: 16 },
	{ left: 92, w: 5, h: 5, drift: 6, delay: -26, dur: 32 },
	{ left: 7, w: 9, h: 9, drift: -9, delay: -14, dur: 39 },
	{ left: 21, w: 6, h: 6, drift: 14, delay: -19, dur: 19 },
	{ left: 38, w: 7, h: 7, drift: -7, delay: -9.5, dur: 30 },
	{ left: 55, w: 5, h: 5, drift: 10, delay: -24, dur: 25 },
	{ left: 71, w: 8, h: 8, drift: -12, delay: -2.2, dur: 25 },
];

/** Copos SVG se leen más finos que las bolitas; subimos tamaño (~1,65×) respecto a la base. */
const snowSizeScale = 1.85;
const snowParticlesRender = [
	...snowParticleBase.map((p) => ({
		...p,
		w: Math.round(p.w * snowSizeScale),
		h: Math.round(p.h * snowSizeScale),
	})),
	...snowParticleBase.map((p) => ({
		...p,
		left: Math.min(99, p.left + 1.5),
		delay: p.delay - 4,
		w: Math.round(p.w * snowSizeScale),
		h: Math.round(p.h * snowSizeScale),
	})),
];

const languageMenuId = "hero-language-menu";
const languageButtonAnchorName = "--hero-language-button";
const languageEntries = [
	{ locale: "en" as const, href: localePath("en") },
	{ locale: "es" as const, href: localePath("es") },
];
---

<section
	id="hero"
	class="hero-cascade relative mb-[-2px] flex min-h-screen flex-col items-center justify-around gap-4 overflow-hidden px-2 md:gap-8 lg:gap-10"
	style="background-image:linear-gradient(180deg,rgba(35,149,231,0.8) 0%, rgba(35,149,231,0.8) 5%, rgba(255, 255, 255, 0.9) 90%, #faf9f2 97%),  url('/images/figma/home-hero.png');
background-size: cover; background-position: center center;"
>
	<div class="hero-snowfield" aria-hidden="true">
		{
			snowParticlesRender.map((p, i) => (
				<span
					class="hero-snowfield-particle"
					style={`left: ${p.left}%; width: ${p.w}px; height: ${p.h}px; --snow-drift-x: ${p.drift}px; animation-delay: ${p.delay}s; animation-duration: ${p.dur}s;`}
				>
					<HeroSnowflakeInner variant={i % 10} />
				</span>
			))
		}
	</div>
	<div class="hero-seam-patch" aria-hidden="true"></div>

	<header
		class="section-inner relative z-10 flex h-[50px] w-full min-w-0 shrink-0 items-center justify-around rounded-[69px] bg-white px-0 shadow-[0_4px_4px_rgba(0,0,0,0.25)] sm:px-2 md:px-3 mt-2 md:mt-4"
	>
		<a
			href="#top"
			class="z-10 flex h-12 w-12 p-1 items-center"
			aria-label={messages.homeLabel}
		>
			<img
				src={assets.navLogo}
				alt=""
				class="pointer-events-none inset-0 size-full object-contain"
			/>
		</a>
		<nav
			class="relative z-30 flex w-full min-w-0 flex-1 flex-nowrap items-center justify-between gap-x-0 overflow-x-auto overflow-y-hidden overscroll-x-contain py-0.5 px-8 md:justify-around lg:justify-evenly"
			aria-label={messages.navAriaLabel}
		>
			<a
				href="#game-details"
				class="font-nunito flex min-h-[2.25rem] shrink-0 items-center justify-center px-0.5 py-0.5 text-[13px] leading-none tracking-tight text-black hover:opacity-80 max-md:whitespace-nowrap sm:px-1 sm:text-[16px] md:p-2.5 md:text-[18px] md:leading-normal md:tracking-wide"
				>{messages.nav.world}</a
			>
			<a
				href="#features"
				class="font-nunito flex min-h-[2.25rem] shrink-0 items-center justify-center px-0.5 py-0.5 text-[13px] leading-none tracking-tight text-black hover:opacity-80 max-md:whitespace-nowrap sm:px-1 sm:text-[16px] md:p-2.5 md:text-[18px] md:leading-normal md:tracking-wide"
				>{messages.nav.game}</a
			>
			<a
				href="#about"
				class="font-nunito flex min-h-[2.25rem] shrink-0 items-center justify-center px-0.5 py-0.5 text-[13px] leading-none tracking-tight text-black hover:opacity-80 max-md:whitespace-nowrap sm:px-1 sm:text-[16px] md:p-2.5 md:text-[18px] md:leading-normal md:tracking-wide"
				>{messages.nav.about}</a
			>
		</nav>
		<div class="hero-language-switcher relative z-40 flex items-center">
			<button
				type="button"
				class="hero-language-trigger z-10 flex h-12 w-12 cursor-pointer items-center p-3 hover:opacity-80"
				aria-label={messages.language.triggerLabel}
				popovertarget={languageMenuId}
				style={`anchor-name: ${languageButtonAnchorName};`}
			>
				<img
					src={assets.changeLanguage}
					alt=""
					class="pointer-events-none inset-0 size-full object-contain"
				/>
			</button>
			<div
				id={languageMenuId}
				popover="auto"
				class="hero-language-popover"
				aria-label={messages.language.menuLabel}
				style={`position-anchor: --hero-language-button; top: anchor(bottom) + 8px; right: anchor(right);`}
			>
				<div class="hero-language-popover__panel" role="menu">
					{
						languageEntries.map((entry) =>
							entry.locale === locale ? (
								<span
									class="hero-language-option hero-language-option--active"
									role="menuitem"
									aria-current="true"
								>
									<span>{messages.language.options[entry.locale]}</span>
									<span class="sr-only">
										{messages.language.currentLabel}
									</span>
								</span>
							) : (
								<a
									href={entry.href}
									class="hero-language-option"
									role="menuitem"
								>
									{messages.language.options[entry.locale]}
								</a>
							),
						)
					}
				</div>
			</div>
		</div>
	</header>

	<img
		src={assets.heroLogo}
		alt="Snowbound logo"
		class="relative z-10 mx-auto block h-auto w-full max-h-[min(42vh,280px)] object-contain object-center md:max-h-[min(52vh,360px)] md:max-w-[452px] lg:max-h-none lg:max-w-[600px]"
		style="filter: drop-shadow(2px 4px 6px black);"
		loading="eager"
		decoding="async"
	/>

	<div
		class="hero-cascade__title relative z-10 font-display text-center text-[clamp(2.25rem,5vw,4rem)] tracking-[0.2px] text-[#2095f7] md:text-[64px] md:leading-[64px] text-shadow-outline text-shadow-white"
	>
		<p class="mb-0 leading-[1.1] whitespace-pre md:leading-[64px]">{messages.titleLines[0]}</p>
		<p class="leading-[1.1] whitespace-pre md:leading-[64px]">{messages.titleLines[1]}</p>
	</div>

	<div
		class="hero-cascade__subtitle relative z-10 flex min-h-9 w-full items-center justify-center overflow-hidden px-2.5 py-2.5"
	>
		<p
			class="font-roboto text-center text-xl font-bold leading-7 tracking-[0.2px] text-snowbound-secondary md:text-[32px] md:leading-8"
		>
			{messages.subtitle}
		</p>
	</div>

	<div
		class="hero-cascade__actions relative z-10 flex w-full max-w-[min(100%,778px)] items-center justify-center flex-col gap-4"
	>
		<button
			type="button"
			data-open-waitlist
			class="hero-cta-button font-tillana flex min-h-[56px] w-full max-w-full items-center justify-center rounded-[50px] bg-snowbound-primary px-4 py-2.5 text-lg leading-none tracking-tight text-white shadow-[0_4px_31px_rgba(0,0,0,0.15)] transition hover:bg-[#0270c2] max-md:whitespace-nowrap sm:min-h-[78px] sm:px-10 sm:py-0 sm:text-[clamp(2rem,6vw,3rem)] sm:tracking-[0.1px] md:h-[102px] md:w-full md:max-w-[778px] md:text-[48px] md:leading-8"
		>
			{messages.cta}
		</button>
		<p
		class="font-roboto max-w-[557px] px-4 text-center text-xl leading-7 tracking-[0.2px] text-snowbound-secondary"
		>
			{messages.supportingCopy}
		</p>
		<div
			class="hero-kickstarter-badge relative mb-8 flex h-[124px] w-[124px] select-none items-center justify-center md:h-[140px] md:w-[140px]"
		>
			<div class="hero-kickstarter-plate" aria-hidden="true">
				<img
					src={assets.kickstarterHex}
					alt=""
					class="block h-full w-full object-contain"
				/>
			</div>
			<div class="relative z-10 flex flex-col items-center justify-center text-center text-xs font-black tracking-wide font-roboto text-[#1978bd]">
				{
					messages.kickstarterLines.map((line) => (
						<p class="leading-tight">{line}</p>
					))
				}
			</div>
		</div>
	</div>

</section>

<style>
	@keyframes hero-cascade-in {
		from {
			opacity: 0;
			transform: translate3d(0, 1rem, 0);
		}
		to {
			opacity: 1;
			transform: translate3d(0, 0, 0);
		}
	}

	#hero.hero-cascade > header {
		animation: hero-cascade-in 0.52s cubic-bezier(0.22, 1, 0.36, 1) 0.06s both;
	}

	#hero.hero-cascade > img {
		animation: hero-cascade-in 0.52s cubic-bezier(0.22, 1, 0.36, 1) 0.13s both;
	}

	.hero-cascade__title > p:nth-child(1) {
		animation: hero-cascade-in 0.52s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both;
	}

	.hero-cascade__title > p:nth-child(2) {
		animation: hero-cascade-in 0.52s cubic-bezier(0.22, 1, 0.36, 1) 0.28s both;
	}

	.hero-cascade__subtitle {
		animation: hero-cascade-in 0.52s cubic-bezier(0.22, 1, 0.36, 1) 0.36s both;
	}

	.hero-cascade__actions > p {
		animation: hero-cascade-in 0.52s cubic-bezier(0.22, 1, 0.36, 1) 0.52s both;
	}

	.hero-cascade__actions > .hero-kickstarter-badge {
		animation: hero-cascade-in 0.52s cubic-bezier(0.22, 1, 0.36, 1) 0.6s both;
	}

	.hero-kickstarter-plate {
		position: absolute;
		inset: 0;
		border-radius: 9999px;
		filter:
			drop-shadow(0 0 22px rgba(0, 0, 0, 0.22))
			drop-shadow(0 0 14px rgba(17, 45, 87, 0.26))
			drop-shadow(0 0 18px rgba(35, 149, 231, 0.28));
	}

	.hero-cta-button {
		animation:
			hero-cascade-in 0.52s cubic-bezier(0.22, 1, 0.36, 1) 0.44s both,
			hero-cta-breathe 2.8s ease-in-out 1s infinite;
		transform-origin: center center;
		will-change: transform, box-shadow;
	}

	.hero-language-popover {
		position: fixed;
		inset: auto 1rem auto auto;
		top: 5rem;
		margin: 0;
		border: 0;
		background: transparent;
		padding: 0;
		color: inherit;
	}

	.hero-language-popover:popover-open {
		display: block;
	}

	.hero-language-popover__panel {
		display: flex;
		min-width: 11rem;
		flex-direction: column;
		gap: 0.35rem;
		border-radius: 1rem;
		border: 1px solid rgba(17, 45, 87, 0.12);
		background: rgba(255, 255, 255, 0.98);
		padding: 0.4rem;
		box-shadow:
			0 18px 34px rgba(17, 45, 87, 0.18),
			0 4px 12px rgba(0, 0, 0, 0.08);
		backdrop-filter: blur(10px);
	}

	.hero-language-option {
		display: flex;
		align-items: center;
		justify-content: space-between;
		border-radius: 9999px;
		padding: 0.65rem 0.9rem;
		font-family: var(--font-nunito);
		font-size: 0.98rem;
		line-height: 1.2;
		color: #112d57;
		text-decoration: none;
		transition:
			background-color 0.18s ease,
			color 0.18s ease,
			opacity 0.18s ease;
	}

	.hero-language-option:hover,
	.hero-language-option:focus-visible {
		background: rgba(35, 149, 231, 0.12);
		outline: none;
	}

	.hero-language-option--active {
		background: #112d57;
		color: white;
		font-weight: 700;
	}

	@supports (top: anchor(bottom)) {
		.hero-language-popover {
			top: calc(anchor(bottom) + 0.45rem);
			right: calc(100vw - anchor(right));
			left: auto;
		}
	}

	.hero-snowfield {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		overflow: hidden;
	}

	.hero-seam-patch {
		position: absolute;
		left: 0;
		right: 0;
		bottom: -3px;
		height: 8px;
		background: #faf9f2;
		pointer-events: none;
		z-index: 1;
	}

	.hero-snowfield-particle {
		--snow-drift-x: 0px;
		--snow-sway: 20px;
		--snow-loops: 3;
		position: absolute;
		top: -12%;
		left: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		min-width: 10px;
		min-height: 10px;
		color: rgba(255, 255, 255, 0.98);
		opacity: 0;
		transform: translate3d(0, -8vh, 0) scale(0.88);
		animation: hero-snowfield-drift 25s linear infinite;
		will-change: transform, opacity;
	}

	/* Rotación sobre el centro del hueco del copo (contenedor cuadrado), no solo del bbox del SVG. */
	.hero-snowfield :global(.hero-snowflake-embed) {
		flex-shrink: 0;
		transform-origin: center center;
		animation: hero-snowflake-spin 20s linear infinite;
	}

	.hero-snowfield-flake {
		display: block;
		width: 100%;
		height: 100%;
		flex-shrink: 0;
		overflow: visible;
		transform-origin: center center;
		transform-box: view-box;
		filter:
			drop-shadow(0 0 3px rgba(255, 255, 255, 1))
			drop-shadow(0 0 8px rgba(255, 255, 255, 0.75))
			drop-shadow(0 0 14px rgba(35, 149, 231, 0.5));
	}

	@keyframes hero-snowflake-spin {
		from {
			transform: rotate(0deg);
		}
		to {
			transform: rotate(360deg);
		}
	}

	.hero-snowfield .hero-snowfield-particle:nth-child(4n + 1) :global(.hero-snowflake-embed) {
		animation-duration: 16s;
	}
	.hero-snowfield .hero-snowfield-particle:nth-child(4n + 2) :global(.hero-snowflake-embed) {
		animation-duration: 22s;
		animation-direction: reverse;
	}
	.hero-snowfield .hero-snowfield-particle:nth-child(4n + 3) :global(.hero-snowflake-embed) {
		animation-duration: 26s;
	}
	.hero-snowfield .hero-snowfield-particle:nth-child(4n + 4) :global(.hero-snowflake-embed) {
		animation-duration: 30s;
		animation-direction: reverse;
	}

	/* Más vueltas de espiral + más vaivén (sin(2π·loops) = 0 en t=1 con loops 3 / 3.5 / 4) */
	.hero-snowfield .hero-snowfield-particle:nth-child(3n + 1) {
		--snow-loops: 3;
	}
	.hero-snowfield .hero-snowfield-particle:nth-child(3n + 2) {
		--snow-loops: 3.5;
	}
	.hero-snowfield .hero-snowfield-particle:nth-child(3n + 3) {
		--snow-loops: 4;
	}
	.hero-snowfield .hero-snowfield-particle:nth-child(5n + 1) {
		--snow-sway: 16px;
	}
	.hero-snowfield .hero-snowfield-particle:nth-child(5n + 2) {
		--snow-sway: 20px;
	}
	.hero-snowfield .hero-snowfield-particle:nth-child(5n + 3) {
		--snow-sway: 24px;
	}
	.hero-snowfield .hero-snowfield-particle:nth-child(5n + 4) {
		--snow-sway: 28px;
	}
	.hero-snowfield .hero-snowfield-particle:nth-child(5n + 5) {
		--snow-sway: 18px;
	}

	@keyframes hero-snowfield-drift {
		0% {
			opacity: 0;
			transform: translate3d(
					calc(
						sin(calc(2 * pi * var(--snow-loops) * 0 * 1rad)) * var(--snow-sway) + 0 * var(--snow-drift-x)
					),
					-8vh,
					0
				)
				scale(0.88);
		}
		10% {
			opacity: 0.72;
			transform: translate3d(
					calc(
						sin(calc(2 * pi * var(--snow-loops) * 0.1 * 1rad)) * var(--snow-sway) + 0.1 * var(--snow-drift-x)
					),
					calc(-8vh + 0.1 * 128vh),
					0
				)
				scale(calc(0.88 + 0.1 * 0.06));
		}
		12.5% {
			opacity: 0.72;
			transform: translate3d(
					calc(
						sin(calc(2 * pi * var(--snow-loops) * 0.125 * 1rad)) * var(--snow-sway) + 0.125 * var(--snow-drift-x)
					),
					calc(-8vh + 0.125 * 128vh),
					0
				)
				scale(calc(0.88 + 0.125 * 0.06));
		}
		25% {
			opacity: 0.72;
			transform: translate3d(
					calc(
						sin(calc(2 * pi * var(--snow-loops) * 0.25 * 1rad)) * var(--snow-sway) + 0.25 * var(--snow-drift-x)
					),
					calc(-8vh + 0.25 * 128vh),
					0
				)
				scale(calc(0.88 + 0.25 * 0.06));
		}
		37.5% {
			opacity: 0.72;
			transform: translate3d(
					calc(
						sin(calc(2 * pi * var(--snow-loops) * 0.375 * 1rad)) * var(--snow-sway) + 0.375 * var(--snow-drift-x)
					),
					calc(-8vh + 0.375 * 128vh),
					0
				)
				scale(calc(0.88 + 0.375 * 0.06));
		}
		50% {
			opacity: 0.62;
			transform: translate3d(
					calc(
						sin(calc(2 * pi * var(--snow-loops) * 0.5 * 1rad)) * var(--snow-sway) + 0.5 * var(--snow-drift-x)
					),
					calc(-8vh + 0.5 * 128vh),
					0
				)
				scale(calc(0.88 + 0.5 * 0.06));
		}
		62.5% {
			opacity: 0.62;
			transform: translate3d(
					calc(
						sin(calc(2 * pi * var(--snow-loops) * 0.625 * 1rad)) * var(--snow-sway) + 0.625 * var(--snow-drift-x)
					),
					calc(-8vh + 0.625 * 128vh),
					0
				)
				scale(calc(0.88 + 0.625 * 0.06));
		}
		75% {
			opacity: 0.62;
			transform: translate3d(
					calc(
						sin(calc(2 * pi * var(--snow-loops) * 0.75 * 1rad)) * var(--snow-sway) + 0.75 * var(--snow-drift-x)
					),
					calc(-8vh + 0.75 * 128vh),
					0
				)
				scale(calc(0.88 + 0.75 * 0.06));
		}
		87.5% {
			opacity: 0.58;
			transform: translate3d(
					calc(

---
import { assets } from "../data/figmaAssets";
---

<section class="min-h-screen flex flex-col items-center gap-4 md:gap-8 lg:gap-10 mb-[-2px] px-2" 
style="background-image:linear-gradient(180deg,rgba(35,149,231,0.8) 0%, rgba(35,149,231,0.8) 5%, rgba(255, 255, 255, 0.9) 90%),  url('/images/figma/home-hero.png');
background-size: cover; background-position: center center;">

	<header
		class="section-inner relative z-10 flex h-[50px] w-full min-w-0 shrink-0 items-center justify-center rounded-[69px] bg-white px-0 shadow-[0_4px_4px_rgba(0,0,0,0.25)] sm:px-2 md:px-3 mt-2 md:mt-4"
	>
		<a
			href="#top"
			class="absolute left-1 top-1/2 z-10 flex h-11 w-[52px] -translate-y-1/2 items-center justify-start overflow-hidden py-1 pl-0 sm:left-3 sm:h-12 sm:w-[112px] sm:py-2 sm:pl-1 md:left-6 md:w-[156px] md:pl-[35px]"
			aria-label="Snowbound home"
		>
			<div class="relative h-full w-full max-w-[48px] sm:max-w-[104px] md:max-w-[186px]">
				<img
					src={assets.navLogo}
					alt=""
					class="pointer-events-none absolute inset-0 size-full max-w-none object-contain object-left"
				/>
			</div>
		</a>
		<nav
			class="relative z-30 flex w-full min-w-0 flex-1 flex-nowrap items-center justify-between gap-x-0 overflow-x-auto overflow-y-hidden overscroll-x-contain py-0.5 pl-[calc(4px+52px+4px)] pr-[calc(4px+52px+4px)] [scrollbar-width:none] sm:pl-[calc(12px+112px+8px)] sm:pr-[calc(12px+112px+8px)] md:overflow-visible md:justify-center md:gap-8 md:pl-[calc(156px+28px)] md:pr-[calc(156px+28px)] [&::-webkit-scrollbar]:hidden"
			aria-label="Primary"
		>
			<a
				href="#top"
				class="font-nunito flex min-h-[2.25rem] shrink-0 items-center justify-center px-0.5 py-0.5 text-[11px] leading-none tracking-tight text-black hover:opacity-80 max-md:whitespace-nowrap sm:px-1 sm:text-sm md:p-2.5 md:text-base md:leading-normal md:tracking-wide"
				>Home</a
			>
			<a
				href="#gameplay"
				class="font-nunito flex min-h-[2.25rem] shrink-0 items-center justify-center px-0.5 py-0.5 text-[11px] leading-none tracking-tight text-black hover:opacity-80 max-md:whitespace-nowrap sm:px-1 sm:text-sm md:p-2.5 md:text-base md:leading-normal md:tracking-wide"
				>The Game</a
			>
			<a
				href="#about"
				class="font-nunito flex min-h-[2.25rem] shrink-0 items-center justify-center px-0.5 py-0.5 text-[11px] leading-none tracking-tight text-black hover:opacity-80 max-md:whitespace-nowrap sm:px-1 sm:text-sm md:p-2.5 md:text-base md:leading-normal md:tracking-wide"
				>About Us</a
			>
			<a
				href="#about"
				class="font-nunito flex min-h-[2.25rem] shrink-0 items-center justify-center px-0.5 py-0.5 text-[11px] leading-none tracking-tight text-black hover:opacity-80 max-md:whitespace-nowrap sm:px-1 sm:text-sm md:p-2.5 md:text-base md:leading-normal md:tracking-wide"
				>Contact</a
			>
		</nav>
	</header>

	<img
		src={assets.heroLogo}
		alt="Snowbound logo"
		class="mx-auto block h-auto w-full max-h-[min(42vh,280px)] object-contain object-center md:max-h-[min(52vh,360px)] md:max-w-[452px] lg:max-h-none lg:max-w-[600px]"
		loading="eager"
		decoding="async"
	/>

	<div
	class="font-display text-center text-[clamp(2rem,5vw,4rem)] tracking-[0.2px] text-[#2095f7] md:text-[64px] md:leading-[64px] text-shadow-outline text-shadow-white"
	>
		<p class="mb-0 leading-[1.1] whitespace-pre md:leading-[64px]">{`Survive the winter. `}</p>
		<p class="leading-[1.1] whitespace-pre md:leading-[64px]">Betray your rivals.</p>
	</div>

	<div
		class="relative z-10 flex min-h-9 w-full items-center justify-center overflow-hidden px-2.5 py-2.5"
	>
		<p
			class="font-roboto text-center text-xl font-bold leading-7 tracking-[0.2px] text-[#112d57] md:text-[32px] md:leading-8"
		>
			A Strategic Board Game of Exploration, Deception and Survival.
		</p>
	</div>

	<div class="relative z-10 flex w-full max-w-[min(100%,778px)] items-center justify-center flex-col gap-4">
		<button
			type="button"
			data-open-waitlist
			class="font-tillana flex min-h-[56px] w-full max-w-full items-center justify-center rounded-[50px] bg-[#0285e4] px-4 py-2.5 text-lg leading-none tracking-tight text-white shadow-[0_4px_31px_rgba(0,0,0,0.15)] transition hover:bg-[#0270c2] max-md:whitespace-nowrap sm:min-h-[78px] sm:px-10 sm:py-0 sm:text-[clamp(2rem,6vw,3rem)] sm:tracking-[0.1px] md:h-[102px] md:w-full md:max-w-[778px] md:text-[48px] md:leading-8"
		>
			JOIN THE WAITLIST
		</button>
		<p
		class="font-roboto relative z-10 max-w-[557px] px-4 text-center text-xl leading-7 tracking-[0.2px] text-[#112d57]"
		>
			Get notified at launch and be the first to enter Snowbound
		</p>
		<div class="mb-8 w-[124px] h-[124px] md:w-[140px] md:h-[140px] flex justify-center flex-col items-center text-center text-xs font-black tracking-wide font-roboto text-[#1978bd]" style="background-image: url('/images/figma/kickstarter-hex.png'); background-size: 100% 100%; background-position: center center;">
			<p class="leading-tight">COMING</p>
			<p class="leading-tight">SOON TO</p>
			<p class="leading-tight">KICKSTARTER</p>
			<p class="leading-tight">PLATFORM</p>
		</div>
	</div>

</section>
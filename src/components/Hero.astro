---
import { assets } from "../data/figmaAssets";

const snowParticles = [
	"particle-1",
	"particle-2",
	"particle-3",
	"particle-4",
	"particle-5",
	"particle-6",
	"particle-7",
	"particle-8",
	"particle-9",
	"particle-10",
	"particle-11",
	"particle-12",
	"particle-13",
	"particle-14",
	"particle-15",
	"particle-16",
	"particle-17",
	"particle-18",
] as const;
---

<section class="relative mb-[-2px] flex min-h-screen flex-col items-center justify-around gap-4 overflow-hidden px-2 md:gap-8 lg:gap-10" 
style="background-image:linear-gradient(180deg,rgba(35,149,231,0.8) 0%, rgba(35,149,231,0.8) 5%, rgba(255, 255, 255, 0.9) 90%, #faf9f2 97%),  url('/images/figma/home-hero.png');
background-size: cover; background-position: center center;">
	<div class="hero-snowfield" aria-hidden="true">
		{snowParticles.map((particleClass) => <span class:list={["hero-snowfield-particle", particleClass]}></span>)}
	</div>
	<div class="hero-seam-patch" aria-hidden="true"></div>

	<header
		class="section-inner relative z-10 flex h-[50px] w-full min-w-0 shrink-0 items-center justify-center rounded-[69px] bg-white px-0 shadow-[0_4px_4px_rgba(0,0,0,0.25)] sm:px-2 md:px-3 mt-2 md:mt-4"
	>
		<a
			href="#top"
			class="absolute left-1 top-1/2 z-10 flex h-11 w-[52px] -translate-y-1/2 items-center justify-start overflow-hidden py-1 pl-0 sm:left-3 sm:h-12 sm:w-[112px] sm:py-2 sm:pl-1 md:left-6 md:w-[156px] md:pl-[35px]"
			aria-label="Snowbound home"
		>
			<div class="relative h-full w-full max-w-[48px] sm:max-w-[104px] md:max-w-[186px]">
				<img
					src={assets.navLogo}
					alt=""
					class="pointer-events-none absolute inset-0 size-full max-w-none object-contain object-left"
				/>
			</div>
		</a>
		<nav
			class="relative z-30 flex w-full min-w-0 flex-1 flex-nowrap items-center justify-between gap-x-0 overflow-x-auto overflow-y-hidden overscroll-x-contain py-0.5 pl-[calc(4px+52px+4px)] pr-[calc(4px+52px+4px)] [scrollbar-width:none] sm:pl-[calc(12px+112px+8px)] sm:pr-[calc(12px+112px+8px)] md:overflow-visible md:justify-center md:gap-8 md:pl-[calc(156px+28px)] md:pr-[calc(156px+28px)] [&::-webkit-scrollbar]:hidden"
			aria-label="Primary"
		>
			<a
				href="#game-details"
				class="font-nunito flex min-h-[2.25rem] shrink-0 items-center justify-center px-0.5 py-0.5 text-[11px] leading-none tracking-tight text-black hover:opacity-80 max-md:whitespace-nowrap sm:px-1 sm:text-sm md:p-2.5 md:text-base md:leading-normal md:tracking-wide"
				>The World</a
			>
			<a
				href="#features"
				class="font-nunito flex min-h-[2.25rem] shrink-0 items-center justify-center px-0.5 py-0.5 text-[11px] leading-none tracking-tight text-black hover:opacity-80 max-md:whitespace-nowrap sm:px-1 sm:text-sm md:p-2.5 md:text-base md:leading-normal md:tracking-wide"
				>The Game</a
			>
			<a
				href="#about"
				class="font-nunito flex min-h-[2.25rem] shrink-0 items-center justify-center px-0.5 py-0.5 text-[11px] leading-none tracking-tight text-black hover:opacity-80 max-md:whitespace-nowrap sm:px-1 sm:text-sm md:p-2.5 md:text-base md:leading-normal md:tracking-wide"
				>About Us</a
			>
		</nav>
	</header>

	<img
		src={assets.heroLogo}
		alt="Snowbound logo"
		class="relative z-10 mx-auto block h-auto w-full max-h-[min(42vh,280px)] object-contain object-center md:max-h-[min(52vh,360px)] md:max-w-[452px] lg:max-h-none lg:max-w-[600px]"
		loading="eager"
		decoding="async"
	/>

	<div
	class="relative z-10 font-display text-center text-[clamp(2rem,5vw,4rem)] tracking-[0.2px] text-[#2095f7] md:text-[64px] md:leading-[64px] text-shadow-outline text-shadow-white"
	>
		<p class="mb-0 leading-[1.1] whitespace-pre md:leading-[64px]">{`Survive the winter. `}</p>
		<p class="leading-[1.1] whitespace-pre md:leading-[64px]">Betray your rivals.</p>
	</div>

	<div
		class="relative z-10 flex min-h-9 w-full items-center justify-center overflow-hidden px-2.5 py-2.5"
	>
		<p
			class="font-roboto text-center text-xl font-bold leading-7 tracking-[0.2px] text-snowbound-secondary md:text-[32px] md:leading-8"
		>
			A Strategic Board Game of Exploration, Deception and Survival.
		</p>
	</div>

	<div class="relative z-10 flex w-full max-w-[min(100%,778px)] items-center justify-center flex-col gap-4">
		<button
			type="button"
			data-open-waitlist
			class="font-tillana flex min-h-[56px] w-full max-w-full items-center justify-center rounded-[50px] bg-snowbound-primary px-4 py-2.5 text-lg leading-none tracking-tight text-white shadow-[0_4px_31px_rgba(0,0,0,0.15)] transition hover:bg-[#0270c2] max-md:whitespace-nowrap sm:min-h-[78px] sm:px-10 sm:py-0 sm:text-[clamp(2rem,6vw,3rem)] sm:tracking-[0.1px] md:h-[102px] md:w-full md:max-w-[778px] md:text-[48px] md:leading-8"
		>
			JOIN THE WAITLIST
		</button>
		<p
		class="font-roboto max-w-[557px] px-4 text-center text-xl leading-7 tracking-[0.2px] text-snowbound-secondary"
		>
			Get notified at launch and be the first to enter Snowbound
		</p>
		<div
			class="hero-kickstarter-badge relative mb-8 flex h-[124px] w-[124px] items-center justify-center md:h-[140px] md:w-[140px]"
		>
			<div class="hero-kickstarter-glow" aria-hidden="true"></div>
			<div class="hero-kickstarter-plate" aria-hidden="true">
				<img
					src={assets.kickstarterHex}
					alt=""
					class="block h-full w-full object-contain"
				/>
			</div>
			<div class="relative z-10 flex flex-col items-center justify-center text-center text-xs font-black tracking-wide font-roboto text-[#1978bd]">
				<p class="leading-tight">COMING</p>
				<p class="leading-tight">SOON TO</p>
				<p class="leading-tight">KICKSTARTER</p>
				<p class="leading-tight">PLATFORM</p>
			</div>
		</div>
	</div>

</section>

<style>
	.hero-kickstarter-badge {
		perspective: 900px;
	}

	.hero-kickstarter-plate,
	.hero-kickstarter-glow {
		position: absolute;
		inset: 0;
		border-radius: 9999px;
		transform-style: preserve-3d;
	}

	.hero-kickstarter-plate {
		filter:
			drop-shadow(0 0 16px rgba(17, 45, 87, 0.16))
			drop-shadow(0 0 10px rgba(35, 149, 231, 0.18))
			drop-shadow(0 0 12px rgba(255, 255, 255, 0.16));
	}

	.hero-kickstarter-glow {
		inset: 8%;
		background:
			radial-gradient(circle at 50% 45%, rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0) 42%),
			radial-gradient(circle, rgba(35, 149, 231, 0.34), rgba(35, 149, 231, 0) 70%);
		filter: blur(18px);
		opacity: 0.96;
		transform: translateZ(-28px) scale(1.24);
	}

	.hero-snowfield {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		overflow: hidden;
	}

	.hero-seam-patch {
		position: absolute;
		left: 0;
		right: 0;
		bottom: -3px;
		height: 8px;
		background: #faf9f2;
		pointer-events: none;
		z-index: 1;
	}

	.hero-snowfield-particle {
		position: absolute;
		top: -12%;
		left: 0;
		width: 10px;
		height: 10px;
		border-radius: 9999px;
		background:
			radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.45) 58%, rgba(255, 255, 255, 0) 100%);
		box-shadow:
			0 0 15px rgba(255, 255, 255, 0.82),
			0 0 26px rgba(35, 149, 231, 0.28);
		opacity: 0;
		transform: translate3d(0, -8vh, 0) scale(0.72);
		animation: hero-snowfield-drift 13s ease-in-out infinite;
		will-change: transform, opacity;
	}

	.hero-snowfield .particle-1 {
		left: 6%;
		width: 5px;
		height: 5px;
		animation-delay: -2s;
		animation-duration: 12s;
	}

	.hero-snowfield .particle-2 {
		left: 14%;
		width: 8px;
		height: 8px;
		animation-delay: -7s;
		animation-duration: 15s;
	}

	.hero-snowfield .particle-3 {
		left: 23%;
		width: 6px;
		height: 6px;
		animation-delay: -4s;
		animation-duration: 11.5s;
	}

	.hero-snowfield .particle-4 {
		left: 31%;
		width: 10px;
		height: 10px;
		animation-delay: -10s;
		animation-duration: 16.5s;
	}

	.hero-snowfield .particle-5 {
		left: 40%;
		width: 7px;
		height: 7px;
		animation-delay: -1s;
		animation-duration: 13.5s;
	}

	.hero-snowfield .particle-6 {
		left: 49%;
		width: 5px;
		height: 5px;
		animation-delay: -8s;
		animation-duration: 12.8s;
	}

	.hero-snowfield .particle-7 {
		left: 58%;
		width: 9px;
		height: 9px;
		animation-delay: -5s;
		animation-duration: 14.8s;
	}

	.hero-snowfield .particle-8 {
		left: 66%;
		width: 6px;
		height: 6px;
		animation-delay: -11s;
		animation-duration: 12.2s;
	}

	.hero-snowfield .particle-9 {
		left: 74%;
		width: 8px;
		height: 8px;
		animation-delay: -3s;
		animation-duration: 15.4s;
	}

	.hero-snowfield .particle-10 {
		left: 82%;
		width: 5px;
		height: 5px;
		animation-delay: -9s;
		animation-duration: 11.8s;
	}

	.hero-snowfield .particle-11 {
		left: 90%;
		width: 9px;
		height: 9px;
		animation-delay: -6s;
		animation-duration: 14.2s;
	}

	.hero-snowfield .particle-12 {
		left: 96%;
		width: 6px;
		height: 6px;
		animation-delay: -12s;
		animation-duration: 13.1s;
	}

	.hero-snowfield .particle-13 {
		left: 10%;
		width: 7px;
		height: 7px;
		animation-delay: -13s;
		animation-duration: 14.6s;
	}

	.hero-snowfield .particle-14 {
		left: 27%;
		width: 5px;
		height: 5px;
		animation-delay: -4.5s;
		animation-duration: 12.6s;
	}

	.hero-snowfield .particle-15 {
		left: 44%;
		width: 9px;
		height: 9px;
		animation-delay: -9.5s;
		animation-duration: 16.1s;
	}

	.hero-snowfield .particle-16 {
		left: 62%;
		width: 6px;
		height: 6px;
		animation-delay: -2.5s;
		animation-duration: 13.9s;
	}

	.hero-snowfield .particle-17 {
		left: 79%;
		width: 7px;
		height: 7px;
		animation-delay: -6.5s;
		animation-duration: 12.4s;
	}

	.hero-snowfield .particle-18 {
		left: 88%;
		width: 5px;
		height: 5px;
		animation-delay: -14s;
		animation-duration: 15.8s;
	}

	@keyframes hero-snowfield-drift {
		0% {
			opacity: 0;
			transform: translate3d(0, -8vh, 0) scale(0.72);
		}
		12% {
			opacity: 0.52;
		}
		55% {
			opacity: 0.4;
			transform: translate3d(14px, 54vh, 0) scale(1);
		}
		100% {
			opacity: 0;
			transform: translate3d(-10px, 108vh, 0) scale(0.78);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-snowfield-particle {
			animation: none;
			transform: none;
			opacity: 0.35;
		}
	}
</style>

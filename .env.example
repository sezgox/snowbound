# Copy to .env — never commit .env
# Public key: EmailJS → Account → General → Public Key

PUBLIC_EMAILJS_PUBLIC_KEY=
PUBLIC_EMAILJS_SERVICE_ID=service_4ro239j
PUBLIC_EMAILJS_TEMPLATE_ID=template_jzwc6ps

# Server-only: Astro /api/waitlist → n8n webhooks (same value as WAITLIST_N8N_SECRET in docker-compose.n8n.yml)
WAITLIST_N8N_SECRET=
# Production URLs from n8n after activating workflows (POST). Local astro dev:
N8N_APPEND_WEBHOOK_URL=http://localhost:5678/webhook/snowbound-waitlist-append
N8N_EMAIL_STATUS_WEBHOOK_URL=http://localhost:5678/webhook/snowbound-waitlist-email-status
# Optional: override when using docker-compose.yml (defaults already use host.docker.internal:5678)
# N8N_DOCKER_APPEND_WEBHOOK_URL=http://host.docker.internal:5678/webhook/snowbound-waitlist-append
# N8N_DOCKER_EMAIL_STATUS_WEBHOOK_URL=http://host.docker.internal:5678/webhook/snowbound-waitlist-email-status
